---
import Layout from '../layouts/Layout.astro';
import CarCard from '../components/CarCard.astro';
import { getCars } from '../lib/db';

let featuredCars: any[] = [];
let topCars: any[] = [];
try {
  const DB = Astro.locals.runtime?.env?.DB;
  if (DB) {
    // Featured/recommended cars
    const featRes = await DB.prepare(
      'SELECT c.*, ci.image_url as primary_image FROM cars c LEFT JOIN car_images ci ON c.id = ci.car_id AND ci.is_primary = 1 WHERE c.status = \'available\' AND c.featured = 1 ORDER BY c.created_at DESC LIMIT 6'
    ).all();
    featuredCars = featRes.results as any[];
    // If no featured, show latest
    if (featuredCars.length === 0) {
      const latest = await getCars(DB, { limit: 6 });
      featuredCars = latest.results;
    }
    // Top deals (with discount)
    const deals = await DB.prepare(
      'SELECT c.*, ci.image_url as primary_image FROM cars c LEFT JOIN car_images ci ON c.id = ci.car_id AND ci.is_primary = 1 WHERE c.status = \'available\' AND c.old_price > c.price ORDER BY (c.old_price - c.price) DESC LIMIT 3'
    ).all();
    topCars = deals.results as any[];
  }
} catch (e) { console.error('DB error index:', e); }

const stats = [
  { value: '500+', label: 'Mașini vândute' },
  { value: '10+', label: 'Ani experiență' },
  { value: '98%', label: 'Clienți mulțumiți' },
  { value: '24h', label: 'Timp răspuns' },
];

const quickBrands = [
  { slug: 'dacia', label: 'Dacia' },
  { slug: 'volkswagen', label: 'VW' },
  { slug: 'bmw', label: 'BMW' },
  { slug: 'ford', label: 'Ford' },
  { slug: 'renault', label: 'Renault' },
  { slug: 'opel', label: 'Opel' },
  { slug: 'skoda', label: 'Skoda' },
  { slug: 'toyota', label: 'Toyota' },
  { slug: 'hyundai', label: 'Hyundai' },
  { slug: 'audi', label: 'Audi' },
  { slug: 'mercedes', label: 'Mercedes' },
  { slug: 'kia', label: 'Kia' },
];

const currentYear = new Date().getFullYear();
const years = Array.from({ length: 20 }, (_, i) => currentYear - i);

const services = [
  {
    icon: '🚗',
    title: 'Parc Auto Variat',
    desc: 'Sute de mașini second hand verificate tehnic, de la mărci premium la accesibile.'
  },
  {
    icon: '💳',
    title: 'Finanțare Rapidă',
    desc: 'Rate avantajoase prin parteneri bancari. Aprobare în 24 de ore, indiferent de venit.'
  },
  {
    icon: '🔍',
    title: 'Mașini Verificate',
    desc: 'Fiecare mașină trece prin inspecție tehnică completă. Fără surprize neplăcute.'
  },
  {
    icon: '📋',
    title: 'Comandă Specială',
    desc: 'Nu găsești ce vrei? Comandăm orice model, orice dotare, direct pentru tine.'
  },
];
---

<Layout title="DAG Auto Buzău - Mașini Second Hand de Calitate">
  <!-- Hero Section -->
  <section class="relative bg-navy-900 text-white overflow-hidden" style="background-color: #0a1a33;">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900 via-navy-800 to-orange-900 opacity-90" style="background: linear-gradient(135deg, #0a1a33 0%, #0f2244 60%, #431407 100%);"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="text-orange-400 font-semibold text-sm uppercase tracking-widest mb-4">Parc Auto Buzău</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          Mașina ta perfectă<br/>
          <span class="text-orange-500">te așteaptă la DAG Auto</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl">
          Parc auto cu sute de mașini second hand verificate. Finanțare rapidă, garanție și service. Vizitează-ne în Buzău pe Calea E85.
        </p>
        <div class="flex flex-wrap gap-4 mb-8">
          <a href="/parc-auto" class="btn-primary text-base px-8 py-4">
            🚗 Caută Mașina Ta
          </a>
          <a href="/cerere-finantare" class="btn-outline text-base px-8 py-4 border-white text-white hover:bg-white hover:text-navy-900">
            💳 Cerere Finanțare
          </a>
        </div>

        <!-- Quick Search Bar (zoom-automobile.ro style) -->
        <form action="/parc-auto" method="GET" class="bg-white rounded-2xl p-3 shadow-2xl max-w-3xl">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
            <select name="make" class="text-gray-700 text-sm px-3 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-orange-400 bg-gray-50">
              <option value="">Orice marcă</option>
              {quickBrands.map(b => <option value={b.label === 'VW' ? 'Volkswagen' : b.label}>{b.label}</option>)}
            </select>
            <select name="min_year" class="text-gray-700 text-sm px-3 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-orange-400 bg-gray-50">
              <option value="">An min</option>
              {years.map(y => <option value={String(y)}>{y}</option>)}
            </select>
            <select name="max_price" class="text-gray-700 text-sm px-3 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-orange-400 bg-gray-50">
              <option value="">Preț max</option>
              {[5000,8000,10000,15000,20000,30000,50000].map(p => (
                <option value={String(p)}>{new Intl.NumberFormat('ro-RO').format(p)} €</option>
              ))}
            </select>
            <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white font-bold rounded-xl px-4 py-3 transition-colors flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              Caută
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Brand Quick Filter -->
  <section class="bg-white border-b border-gray-100 py-5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 overflow-x-auto pb-1 scrollbar-hide">
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest shrink-0">Mărci:</span>
        {quickBrands.map(b => (
          <a
            href={`/masini-second-hand/${b.slug}`}
            class="shrink-0 px-5 py-2 rounded-full border border-gray-200 text-sm font-semibold text-gray-700 hover:border-orange-400 hover:text-orange-600 hover:bg-orange-50 transition-all whitespace-nowrap"
          >
            {b.label}
          </a>
        ))}
        <a href="/parc-auto" class="shrink-0 px-5 py-2 rounded-full bg-orange-500 text-white text-sm font-semibold hover:bg-orange-600 transition-colors whitespace-nowrap">
          Toate →
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-orange-500 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-white text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl md:text-4xl font-extrabold">{s.value}</div>
            <div class="text-sm font-medium opacity-90 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Top Deals (reduceri) -->
  {topCars.length > 0 && (
    <section class="py-12 bg-red-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl font-extrabold text-gray-900">🔥 Oferte Speciale</h2>
            <p class="text-gray-500 text-sm">Prețuri reduse pentru vânzare rapidă</p>
          </div>
          <a href="/parc-auto" class="text-sm text-orange-500 font-semibold hover:underline">Vezi toate →</a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {topCars.map((car: any) => (
            <CarCard
              id={car.id} title={car.title} slug={car.slug}
              make={car.make} model={car.model} year={car.year}
              price={car.price} old_price={car.old_price}
              mileage={car.mileage} fuel_type={car.fuel_type}
              transmission={car.transmission} featured={car.featured}
              primary_image={car.primary_image}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Cars -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="section-title">⭐ Mașini Recomandate</h2>
        <p class="section-subtitle">Selecția noastră pentru tine</p>
      </div>

      {featuredCars.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredCars.map((car: any) => (
            <CarCard
              id={car.id} title={car.title} slug={car.slug}
              make={car.make} model={car.model} year={car.year}
              price={car.price} old_price={car.old_price}
              mileage={car.mileage} fuel_type={car.fuel_type}
              transmission={car.transmission} featured={car.featured}
              primary_image={car.primary_image}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 text-gray-500">
          <p class="text-xl mb-4">🚗 Stocul se actualizează în curând</p>
          <p>Contactează-ne pentru disponibilitate.</p>
        </div>
      )}

      <div class="text-center mt-10">
        <a href="/parc-auto" class="btn-primary text-base px-10 py-4">
          Vezi Toate Mașinile →
        </a>
      </div>
    </div>
  </section>

  <!-- Trade-in Banner -->
  <section class="py-10 bg-navy-900 text-white" style="background-color: #0f2244;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h2 class="text-2xl font-bold mb-1">🔄 Dai mașina veche, iei una nouă</h2>
          <p class="text-gray-300">Evaluăm mașina ta pe loc. Preț corect, tranzacție rapidă.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="/contact" class="btn-primary">Solicită Evaluare</a>
          <a href="tel:0721586534" class="btn-outline border-white text-white hover:bg-white hover:text-navy-900">📞 Sună Acum</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Financing Partners / Parteneri Financiari -->
  <section class="py-14 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-2">Parteneri Financiari</h2>
        <p class="text-gray-500">Calculează rata lunară direct pe site-ul băncii sau solicită finanțare prin noi</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        <!-- BT - Banca Transilvania (primary partner) -->
        <a
          href="https://www.bancatransilvania.ro/persoane-fizice/credite/credite-auto/"
          target="_blank"
          rel="noopener"
          class="group relative flex flex-col items-center justify-center gap-4 p-8 rounded-2xl border-2 border-orange-400 bg-orange-50 hover:bg-orange-100 hover:shadow-lg transition-all"
        >
          <div class="absolute top-3 right-3 bg-orange-500 text-white text-xs font-bold px-2 py-0.5 rounded-full">
            Partener principal
          </div>
          <!-- BT Logo text representation -->
          <div class="flex items-center gap-3">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center shadow-md" style="background: linear-gradient(135deg, #0f2244 0%, #1a3a6b 100%);">
              <span class="text-white font-black text-2xl" style="font-family: 'Arial Black', sans-serif; letter-spacing: -1px;">BT</span>
            </div>
            <div class="text-left">
              <div class="font-extrabold text-gray-900 text-lg leading-tight">Banca</div>
              <div class="font-extrabold text-orange-600 text-lg leading-tight">Transilvania</div>
            </div>
          </div>
          <div class="text-center">
            <div class="text-sm text-gray-600 mb-2">Credit auto cu avans de la <span class="font-bold text-gray-900">15%</span></div>
            <div class="text-sm text-gray-600">Dobândă fixă, aprobare rapidă</div>
          </div>
          <div class="flex items-center gap-2 bg-orange-500 group-hover:bg-orange-600 text-white font-bold text-sm px-5 py-2.5 rounded-xl transition-colors w-full justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Calculator Rate BT →
          </div>
        </a>

        <!-- BCR -->
        <a
          href="https://www.bcr.ro/ro/persoane/credite/credit-auto"
          target="_blank"
          rel="noopener"
          class="group flex flex-col items-center justify-center gap-4 p-8 rounded-2xl border border-gray-200 bg-gray-50 hover:border-blue-300 hover:bg-blue-50 hover:shadow-md transition-all"
        >
          <div class="flex items-center gap-3">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center shadow-sm" style="background: #003399;">
              <span class="text-white font-black text-xl" style="font-family: 'Arial Black', sans-serif;">BCR</span>
            </div>
            <div class="text-left">
              <div class="font-extrabold text-gray-900 text-lg leading-tight">BCR</div>
              <div class="text-gray-500 text-sm">Credit auto</div>
            </div>
          </div>
          <div class="text-sm text-gray-600 text-center">Finanțare flexibilă, până la 72 luni</div>
          <div class="flex items-center gap-2 border border-blue-300 text-blue-700 font-semibold text-sm px-5 py-2.5 rounded-xl group-hover:bg-blue-600 group-hover:text-white group-hover:border-blue-600 transition-colors w-full justify-center">
            Calculator Rate BCR →
          </div>
        </a>

        <!-- ING -->
        <a
          href="https://www.ing.ro/persoane-fizice/credite/credit-auto.html"
          target="_blank"
          rel="noopener"
          class="group flex flex-col items-center justify-center gap-4 p-8 rounded-2xl border border-gray-200 bg-gray-50 hover:border-orange-300 hover:bg-orange-50 hover:shadow-md transition-all"
        >
          <div class="flex items-center gap-3">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center shadow-sm" style="background: #ff6200;">
              <span class="text-white font-black text-xl" style="font-family: 'Arial Black', sans-serif;">ING</span>
            </div>
            <div class="text-left">
              <div class="font-extrabold text-gray-900 text-lg leading-tight">ING Bank</div>
              <div class="text-gray-500 text-sm">Credit auto</div>
            </div>
          </div>
          <div class="text-sm text-gray-600 text-center">Aprobare online, proces 100% digital</div>
          <div class="flex items-center gap-2 border border-orange-300 text-orange-600 font-semibold text-sm px-5 py-2.5 rounded-xl group-hover:bg-orange-500 group-hover:text-white group-hover:border-orange-500 transition-colors w-full justify-center">
            Calculator Rate ING →
          </div>
        </a>
      </div>

      <!-- CTA -->
      <div class="bg-gray-900 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-5" style="background: linear-gradient(135deg, #0f2244 0%, #1e3a6e 100%);">
        <div>
          <h3 class="text-xl font-bold text-white mb-1">Nu știi ce bancă să alegi?</h3>
          <p class="text-gray-300 text-sm">Completează cererea noastră și te contactăm cu cea mai bună ofertă din piață.</p>
        </div>
        <div class="flex gap-3 shrink-0">
          <a href="/cerere-finantare" class="bg-orange-500 hover:bg-orange-600 text-white font-bold px-6 py-3 rounded-xl transition-colors text-sm">
            Solicită Ofertă →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="section-title">De Ce DAG Auto?</h2>
        <p class="section-subtitle">Suntem partenerii tăi de încredere în Buzău</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map(s => (
          <div class="text-center p-6 rounded-xl border border-gray-100 hover:border-orange-200 hover:shadow-md transition-all">
            <div class="text-4xl mb-4">{s.icon}</div>
            <h3 class="font-bold text-navy-800 text-lg mb-2" style="color: #0f2244;">{s.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Forms CTA -->
  <section class="py-16 bg-navy-900 text-white" style="background-color: #0f2244;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Servicii Personalizate</h2>
        <p class="text-lg text-gray-300">Alege serviciul potrivit pentru tine</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { href: '/comanda-speciala', label: 'Comandă Specială', icon: '📋', desc: 'Orice model, la cerere' },
          { href: '/cerere-finantare', label: 'Cerere Finanțare', icon: '💳', desc: 'Rate personalizate' },
          { href: '/test-drive', label: 'Test Drive', icon: '🏎️', desc: 'Încearcă înainte să cumperi' },
          { href: '/programeaza-vizita', label: 'Programează Vizită', icon: '📅', desc: 'Vino fără așteptare' },
        ].map(item => (
          <a href={item.href} class="flex flex-col items-center text-center p-6 bg-white/10 rounded-xl hover:bg-orange-500 transition-all duration-300 group">
            <span class="text-3xl mb-3">{item.icon}</span>
            <span class="font-semibold text-white mb-1">{item.label}</span>
            <span class="text-sm text-gray-300 group-hover:text-white/90">{item.desc}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="section-title">Vino Să Ne Vizitezi</h2>
          <p class="text-gray-600 mb-6">Parcul nostru auto se află pe Calea E85 la intrarea în Buzău, ușor accesibil din toate direcțiile.</p>
          <ul class="space-y-4">
            {[
              { icon: '📍', label: 'Adresă', value: 'Calea E85 nr.37, Com. Mărăcineni, Buzău' },
              { icon: '📞', label: 'Telefon', value: '0721 586 534', href: 'tel:0721586534' },
              { icon: '✉️', label: 'Email', value: 'contact@dagauto.ro', href: 'mailto:contact@dagauto.ro' },
              { icon: '🕐', label: 'Program', value: 'Luni–Sâmbătă: 9:00–18:00' },
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="text-2xl">{item.icon}</span>
                <div>
                  <span class="font-semibold text-gray-700 block text-sm">{item.label}</span>
                  {item.href ? (
                    <a href={item.href} class="text-orange-600 hover:underline">{item.value}</a>
                  ) : (
                    <span class="text-gray-600">{item.value}</span>
                  )}
                </div>
              </li>
            ))}
          </ul>
          <div class="flex gap-4 mt-8">
            <a href="/contact" class="btn-primary">Trimite Mesaj</a>
            <a href="/programeaza-vizita" class="btn-outline">Programează Vizită</a>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg h-80">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2811.5!2d26.8200!3d45.1500!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zDAG+Auto!5e0!3m2!1sro!2sro!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="DAG Auto Buzău - Locație"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
