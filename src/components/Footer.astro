---
const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-gray-300" style="background-color: #0a1a33;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center mb-4">
          <img src="/logo-white.svg" alt="DAG Auto" class="h-8 w-auto mb-3" width="140" height="32" />
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Parc auto de încredere în Buzău. Mașini second hand verificate, finanțare rapidă și servicii complete.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Link-uri Rapide</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/parc-auto" class="hover:text-orange-400 transition-colors">Parc Auto</a></li>
          <li><a href="/blog" class="hover:text-orange-400 transition-colors">Blog</a></li>
          <li><a href="/contact" class="hover:text-orange-400 transition-colors">Contact</a></li>
          <li><a href="/masini-second-hand-buzau" class="hover:text-orange-400 transition-colors">Mașini Second Hand Buzău</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold mb-4">Servicii</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/comanda-speciala" class="hover:text-orange-400 transition-colors">Comandă Specială</a></li>
          <li><a href="/cerere-finantare" class="hover:text-orange-400 transition-colors">Cerere Finanțare</a></li>
          <li><a href="/test-drive" class="hover:text-orange-400 transition-colors">Test Drive</a></li>
          <li><a href="/programeaza-vizita" class="hover:text-orange-400 transition-colors">Programează Vizită</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contact</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <span class="text-orange-400 mt-0.5">📍</span>
            <span>Calea E85 nr.37, Com. Mărăcineni, Buzău</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-orange-400">📞</span>
            <a href="tel:0721586534" class="hover:text-orange-400 transition-colors">0721 586 534</a>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-orange-400">✉️</span>
            <a href="mailto:contact@dagauto.ro" class="hover:text-orange-400 transition-colors">contact@dagauto.ro</a>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-orange-400">🕐</span>
            <span>Luni–Sâmbătă: 9:00–18:00</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <p>&copy; {year} DAG Auto. Toate drepturile rezervate.</p>
      <p>
        <a href="/masini-second-hand-buzau" class="hover:text-orange-400 transition-colors">Mașini Second Hand Buzău</a>
      </p>
    </div>
  </div>
</footer>
