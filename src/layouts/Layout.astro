---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = 'DAG Auto - Mașini second hand de calitate în Buzău. Parc auto cu sute de mașini verificate, finanțare rapidă și garanție.',
  image = '/og-image.jpg',
  canonicalUrl
} = Astro.props;

const siteUrl = 'https://dagauto.ro';
const fullTitle = title.includes('DAG Auto') ? title : `${title} | DAG Auto Buzău`;
---

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl || `${siteUrl}${Astro.url.pathname}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${image}`} />
  <meta property="og:url" content={canonicalUrl || `${siteUrl}${Astro.url.pathname}`} />
  <meta property="og:site_name" content="DAG Auto Buzău" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${image}`} />

  <!-- Schema.org AutoDealer -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AutoDealer",
    "name": "DAG Auto",
    "url": siteUrl,
    "telephone": "0721586534",
    "email": "contact@dagauto.ro",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calea E85 nr.37",
      "addressLocality": "Com. Mărăcineni",
      "addressRegion": "Buzău",
      "addressCountry": "RO"
    },
    "openingHours": "Mo-Fr 09:00-18:00",
    "priceRange": "€€"
  })} />

  <!-- Slot for page-specific head content (eg. Schema.org Car) -->
  <slot name="head" />
</head>
<body class="bg-white text-gray-900" style="font-family: 'Inter', system-ui, sans-serif;">
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  <!-- Cookie Consent GDPR -->
  <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[60] bg-gray-900 text-white p-4 shadow-2xl hidden">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between">
      <p class="text-sm text-gray-300 flex-1">
        Folosim cookie-uri pentru a îmbunătăți experiența ta pe site. Prin continuarea navigării, ești de acord cu
        <a href="/politica-cookies" class="text-orange-400 hover:underline">Politica de Cookies</a> și
        <a href="/politica-confidentialitate" class="text-orange-400 hover:underline">Politica de Confidențialitate</a>.
      </p>
      <div class="flex gap-3 shrink-0">
        <button id="cookie-decline" class="text-sm px-4 py-2 border border-gray-600 rounded-lg hover:bg-gray-800 transition-colors">
          Refuz
        </button>
        <button id="cookie-accept" class="text-sm px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-lg font-semibold transition-colors">
          Accept toate
        </button>
      </div>
    </div>
  </div>

  <script>
    const banner = document.getElementById('cookie-banner');
    const consent = localStorage.getItem('dagauto_cookie_consent');
    if (!consent && banner) banner.classList.remove('hidden');

    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      localStorage.setItem('dagauto_cookie_consent', 'accepted');
      banner?.classList.add('hidden');
    });
    document.getElementById('cookie-decline')?.addEventListener('click', () => {
      localStorage.setItem('dagauto_cookie_consent', 'declined');
      banner?.classList.add('hidden');
    });
  </script>

  <!-- WhatsApp Floating Button -->
  <a href="https://wa.me/40721586534?text=Bun%C4%83%20ziua!%20Sunt%20interesat%20de%20ma%C8%99inile%20dumneavoastr%C4%83."
    target="_blank" rel="noopener"
    class="fixed bottom-6 right-6 z-50 flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-semibold px-4 py-3 rounded-full shadow-lg hover:shadow-xl transition-all group"
    aria-label="Contactează-ne pe WhatsApp"
  >
    <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="hidden sm:inline">WhatsApp</span>
  </a>
</body>
</html>
