---
import Layout from '../../layouts/Layout.astro';
import { getBlogPostBySlug } from '../../lib/db';

const { slug } = Astro.params;
const DB = Astro.locals.runtime?.env?.DB;
if (!DB) return Astro.redirect('/blog');

const post = await getBlogPostBySlug(DB, slug!);
if (!post) return Astro.redirect('/blog');
---

<Layout
  title={post.title}
  description={post.excerpt || post.title}
  image={post.image_url}
>
  <section class="bg-navy-900 text-white py-6" style="background-color: #0f2244;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-400 mb-4">
        <a href="/" class="hover:text-orange-400">Acasă</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="hover:text-orange-400">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-gray-200">{post.title}</span>
      </nav>
    </div>
  </section>

  <article class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {post.image_url && (
        <img
          src={post.image_url}
          alt={post.title}
          class="w-full rounded-xl shadow-md mb-8 object-cover max-h-96"
          loading="eager"
        />
      )}
      <p class="text-sm text-gray-400 mb-3">{new Date(post.created_at).toLocaleDateString('ro-RO', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6">{post.title}</h1>
      <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed" set:html={post.content} />

      <div class="mt-12 pt-8 border-t border-gray-100 flex flex-wrap gap-4">
        <a href="/blog" class="btn-outline">← Înapoi la Blog</a>
        <a href="/parc-auto" class="btn-primary">Caută Mașina Ta →</a>
      </div>
    </div>
  </article>
</Layout>
