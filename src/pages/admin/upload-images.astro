---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Upload Poze Mașini">
  <div class="max-w-2xl mx-auto py-8 px-4">
    <h1 class="text-2xl font-bold text-gray-800 mb-2">Upload Poze Mașini</h1>
    <p class="text-gray-500 mb-6">Selectează toate pozele descărcate — sistemul le asociază automat cu mașinile după nume de fișier.</p>

    <div
      id="drop-zone"
      class="border-4 border-dashed border-gray-300 rounded-2xl p-12 text-center cursor-pointer hover:border-orange-400 transition-colors"
    >
      <div class="text-5xl mb-4">📁</div>
      <p class="text-lg font-semibold text-gray-700 mb-2">Trage pozele aici</p>
      <p class="text-gray-400 mb-4">sau</p>
      <label class="cursor-pointer bg-orange-500 hover:bg-orange-600 text-white font-bold px-6 py-3 rounded-xl transition-colors">
        Selectează fișiere
        <input type="file" id="file-input" multiple accept="image/*" class="hidden" />
      </label>
      <p class="text-sm text-gray-400 mt-4">JPG, JPEG, PNG, WebP — oricâte fișiere</p>
    </div>

    <div id="selected-info" class="hidden mt-4 p-4 bg-blue-50 rounded-xl text-blue-700 font-semibold"></div>

    <button
      id="upload-btn"
      class="hidden mt-4 w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-4 rounded-xl text-lg transition-colors"
    >
      Încarcă pozele →
    </button>

    <div id="progress" class="hidden mt-6 space-y-3"></div>
    <div id="results" class="hidden mt-6"></div>
  </div>

  <script>
    const dropZone = document.getElementById('drop-zone')!;
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const selectedInfo = document.getElementById('selected-info')!;
    const uploadBtn = document.getElementById('upload-btn')!;
    const progressEl = document.getElementById('progress')!;
    const resultsEl = document.getElementById('results')!;

    let selectedFiles: File[] = [];

    function updateUI() {
      if (selectedFiles.length > 0) {
        selectedInfo.textContent = `${selectedFiles.length} fișiere selectate`;
        selectedInfo.classList.remove('hidden');
        uploadBtn.classList.remove('hidden');
      }
    }

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('border-orange-400', 'bg-orange-50');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-orange-400', 'bg-orange-50');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-orange-400', 'bg-orange-50');
      selectedFiles = Array.from(e.dataTransfer?.files || []);
      updateUI();
    });

    fileInput.addEventListener('change', () => {
      selectedFiles = Array.from(fileInput.files || []);
      updateUI();
    });

    uploadBtn.addEventListener('click', async () => {
      if (selectedFiles.length === 0) return;

      uploadBtn.disabled = true;
      uploadBtn.textContent = 'Se încarcă...';
      progressEl.classList.remove('hidden');
      progressEl.innerHTML = '<div class="text-gray-500">Se procesează...</div>';

      // Upload in batches of 20
      const batchSize = 20;
      let totalOk = 0;
      let totalNoMatch = 0;
      let totalErrors = 0;
      const allResults: any[] = [];

      for (let i = 0; i < selectedFiles.length; i += batchSize) {
        const batch = selectedFiles.slice(i, i + batchSize);
        const formData = new FormData();
        batch.forEach(f => formData.append('images', f));

        progressEl.innerHTML = `<div class="text-blue-600 font-semibold">Batch ${Math.floor(i/batchSize)+1} / ${Math.ceil(selectedFiles.length/batchSize)} — ${i + batch.length} din ${selectedFiles.length} fișiere...</div>`;

        try {
          const res = await fetch('/api/admin-upload-images', {
            method: 'POST',
            body: formData
          });
          const data = await res.json();
          totalOk += data.summary?.ok || 0;
          totalNoMatch += data.summary?.no_match || 0;
          totalErrors += data.summary?.errors || 0;
          allResults.push(...(data.results || []));
        } catch (err) {
          progressEl.innerHTML += `<div class="text-red-500">Eroare batch ${Math.floor(i/batchSize)+1}: ${err}</div>`;
        }
      }

      // Show final results
      progressEl.classList.add('hidden');
      resultsEl.classList.remove('hidden');
      resultsEl.innerHTML = `
        <div class="rounded-xl p-5 ${totalOk > 0 ? 'bg-green-50 border border-green-200' : 'bg-yellow-50 border border-yellow-200'}">
          <div class="text-xl font-bold mb-3 ${totalOk > 0 ? 'text-green-700' : 'text-yellow-700'}">
            ${totalOk > 0 ? '✅ Gata!' : '⚠️ Rezultate'}
          </div>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div class="bg-white rounded-lg p-3">
              <div class="text-2xl font-black text-green-600">${totalOk}</div>
              <div class="text-sm text-gray-500">Încărcate</div>
            </div>
            <div class="bg-white rounded-lg p-3">
              <div class="text-2xl font-black text-yellow-600">${totalNoMatch}</div>
              <div class="text-sm text-gray-500">Fără potrivire</div>
            </div>
            <div class="bg-white rounded-lg p-3">
              <div class="text-2xl font-black text-red-600">${totalErrors}</div>
              <div class="text-sm text-gray-500">Erori</div>
            </div>
          </div>
          ${totalNoMatch > 0 ? `<p class="text-sm text-yellow-600 mt-3">Fișierele fără potrivire nu au fost găsite în baza de date (pot fi ignorate dacă sunt poze noi).</p>` : ''}
        </div>
      `;

      uploadBtn.textContent = 'Încarcă din nou';
      uploadBtn.disabled = false;
    });
  </script>
</AdminLayout>
