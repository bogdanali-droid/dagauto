---
import Layout from '../../layouts/Layout.astro';
import { getBlogPosts } from '../../lib/db';

let posts: any[] = [];
try {
  const DB = Astro.locals.runtime?.env?.DB;
  if (DB) posts = (await getBlogPosts(DB, 'published', 20)).results;
} catch (e) { console.error('DB error blog:', e); }
---

<Layout
  title="Blog Auto - Sfaturi și Noutăți"
  description="Sfaturi auto, noutăți din industrie și ghiduri de cumpărare mașini second hand de la experții DAG Auto Buzău."
>
  <section class="bg-navy-900 text-white py-10" style="background-color: #0f2244;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2">Blog Auto</h1>
      <p class="text-gray-300">Sfaturi, ghiduri și noutăți din lumea auto</p>
    </div>
  </section>

  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`} class="group bg-white rounded-xl shadow-md hover:shadow-xl transition-all overflow-hidden">
              {post.image_url && (
                <img
                  src={post.image_url}
                  alt={post.title}
                  class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              )}
              <div class="p-5">
                <p class="text-xs text-gray-400 mb-2">{new Date(post.created_at).toLocaleDateString('ro-RO')}</p>
                <h2 class="font-bold text-lg text-gray-900 mb-2 group-hover:text-orange-600 transition-colors line-clamp-2">{post.title}</h2>
                {post.excerpt && <p class="text-gray-600 text-sm line-clamp-3">{post.excerpt}</p>}
                <span class="text-orange-500 text-sm font-semibold mt-3 inline-block group-hover:underline">Citește mai mult →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-5xl mb-4">📝</p>
          <h2 class="text-2xl font-bold text-gray-700 mb-2">Articolele vor apărea în curând</h2>
          <p class="text-gray-500">Revino curând pentru sfaturi auto și noutăți.</p>
        </div>
      )}
    </div>
  </section>
</Layout>
