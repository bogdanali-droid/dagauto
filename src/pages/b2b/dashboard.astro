---
import B2BLayout from '../../layouts/B2BLayout.astro';
import { getB2BUser } from '../../lib/b2b-auth';

const DB = Astro.locals.runtime?.env?.DB;
const secret = Astro.locals.runtime?.env?.SESSION_SECRET || 'dev-secret-change-in-prod';
const user = DB ? await getB2BUser(Astro.request, DB, secret) : null;

if (!user) return Astro.redirect('/b2b/login');

// Get user's cars
const carsResult = await DB.prepare(`
  SELECT c.id, c.title, c.price, c.original_price, c.markup_pct, c.status, c.slug,
         ci.image_url as primary_image
  FROM cars c
  LEFT JOIN car_images ci ON ci.car_id = c.id AND ci.is_primary = 1
  WHERE c.b2b_user_id = ?
  ORDER BY c.id DESC
`).bind(user.id).all();

const cars = (carsResult.results || []) as any[];
const stats = {
  total: cars.length,
  available: cars.filter((c: any) => c.status === 'available').length,
  reserved: cars.filter((c: any) => c.status === 'reserved').length,
  sold: cars.filter((c: any) => c.status === 'sold').length,
};
---

<B2BLayout title="Dashboard B2B">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-extrabold text-gray-800">Bună, {user.name}!</h1>
        <p class="text-gray-500 text-sm mt-1">{user.email} {user.company ? `· ${user.company}` : ''}</p>
      </div>
      <a href="/b2b/add-car" class="bg-orange-500 hover:bg-orange-600 text-white font-bold px-5 py-2.5 rounded-xl transition-colors">
        + Adaugă Mașină
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-4 gap-4 mb-8">
      {[
        { label: 'Total', value: stats.total, color: 'text-gray-800' },
        { label: 'Active', value: stats.available, color: 'text-green-600' },
        { label: 'Rezervate', value: stats.reserved, color: 'text-yellow-600' },
        { label: 'Vândute', value: stats.sold, color: 'text-blue-600' },
      ].map(s => (
        <div class="bg-white rounded-xl p-5 text-center shadow-sm border border-gray-100">
          <div class={`text-3xl font-black ${s.color}`}>{s.value}</div>
          <div class="text-sm text-gray-500 mt-1">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Cars list -->
    {cars.length === 0 ? (
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-16 text-center">
        <div class="text-6xl mb-4">🚗</div>
        <h2 class="text-xl font-bold text-gray-700 mb-2">Nu ai nicio mașină listată</h2>
        <p class="text-gray-400 mb-6">Adaugă prima ta mașină și ea va apărea pe dagauto.ro</p>
        <a href="/b2b/add-car" class="bg-orange-500 hover:bg-orange-600 text-white font-bold px-6 py-3 rounded-xl transition-colors inline-block">
          Adaugă prima mașină →
        </a>
      </div>
    ) : (
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
              <th class="text-left px-6 py-4 font-semibold text-gray-600">Mașină</th>
              <th class="text-right px-4 py-4 font-semibold text-gray-600">Prețul tău</th>
              <th class="text-right px-4 py-4 font-semibold text-gray-600">Preț afișat (+15%)</th>
              <th class="text-center px-4 py-4 font-semibold text-gray-600">Status</th>
              <th class="px-4 py-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {cars.map((car: any) => {
              const statusColors: {[k: string]: string} = {
                available: 'bg-green-100 text-green-700',
                reserved: 'bg-yellow-100 text-yellow-700',
                sold: 'bg-blue-100 text-blue-700',
                pending: 'bg-gray-100 text-gray-600',
              };
              const statusLabels: {[k: string]: string} = {
                available: 'Activ',
                reserved: 'Rezervat',
                sold: 'Vândut',
                pending: 'În așteptare',
              };
              return (
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      {car.primary_image ? (
                        <img src={car.primary_image} alt={car.title} class="w-12 h-9 object-cover rounded-lg" />
                      ) : (
                        <div class="w-12 h-9 bg-gray-100 rounded-lg flex items-center justify-center text-gray-300">🚗</div>
                      )}
                      <span class="font-semibold text-gray-800">{car.title}</span>
                    </div>
                  </td>
                  <td class="px-4 py-4 text-right text-gray-600 font-medium">
                    {car.original_price ? `${car.original_price.toLocaleString('ro-RO')} €` : '—'}
                  </td>
                  <td class="px-4 py-4 text-right font-bold text-gray-800">
                    {car.price ? `${car.price.toLocaleString('ro-RO')} €` : '—'}
                  </td>
                  <td class="px-4 py-4 text-center">
                    <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold ${statusColors[car.status] || 'bg-gray-100 text-gray-600'}`}>
                      {statusLabels[car.status] || car.status}
                    </span>
                  </td>
                  <td class="px-4 py-4">
                    <a href={`/parc-auto/${car.slug}`} target="_blank" class="text-orange-500 hover:underline text-xs font-semibold">
                      Vezi →
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>
</B2BLayout>
