---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mașini Salvate | DAG Auto Buzău" description="Mașinile tale salvate la DAG Auto Buzău">
  <section class="bg-navy-900 text-white py-10" style="background-color: #0f2244;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl font-extrabold mb-2">❤️ Mașini Salvate</h1>
      <p class="text-gray-300">Mașinile pe care le-ai salvat pentru mai târziu</p>
    </div>
  </section>

  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="loading" class="text-center py-16 text-gray-400">Se încarcă...</div>
      <div id="empty" class="hidden text-center py-16">
        <div class="text-6xl mb-4">💔</div>
        <h2 class="text-xl font-bold text-gray-700 mb-2">Nicio mașină salvată</h2>
        <p class="text-gray-500 mb-6">Apasă pe ❤️ pe orice mașină pentru a o salva aici</p>
        <a href="/parc-auto" class="btn-primary">Caută Mașini</a>
      </div>
      <div id="cars-grid" class="hidden grid sm:grid-cols-2 lg:grid-cols-3 gap-6"></div>
    </div>
  </section>
</Layout>

<script>
  async function loadFavorites() {
    const loading = document.getElementById('loading')!;
    const empty = document.getElementById('empty')!;
    const grid = document.getElementById('cars-grid')!;

    let ids: number[] = [];
    try {
      ids = JSON.parse(localStorage.getItem('dagauto_favorites') || '[]');
    } catch {}

    if (ids.length === 0) {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    // Fetch each car
    const results = await Promise.allSettled(
      ids.map(id => fetch(`/api/car/${id}`).then(r => r.ok ? r.json() : null))
    );
    const cars = results
      .filter(r => r.status === 'fulfilled' && r.value)
      .map((r: any) => r.value);

    loading.classList.add('hidden');

    if (cars.length === 0) {
      empty.classList.remove('hidden');
      return;
    }

    grid.classList.remove('hidden');
    grid.innerHTML = cars.map(car => `
      <div class="bg-white rounded-xl shadow-md overflow-hidden relative">
        <button class="remove-fav absolute top-3 right-3 z-10 w-9 h-9 bg-white/90 rounded-full shadow flex items-center justify-center"
          data-id="${car.id}">
          <svg class="w-5 h-5 text-orange-500" fill="#f97316" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </button>
        <a href="/parc-auto/${car.slug}">
          ${car.primary_image
            ? `<img src="${car.primary_image}" alt="${car.title}" class="w-full aspect-[4/3] object-cover">`
            : `<div class="w-full aspect-[4/3] bg-gray-100 flex items-center justify-center text-5xl">🚗</div>`
          }
          <div class="p-4">
            <h3 class="font-bold text-gray-900 mb-1">${car.title}</h3>
            <p class="text-sm text-gray-500 mb-3">${car.year} · ${new Intl.NumberFormat('ro-RO').format(car.mileage)} km · ${car.fuel_type}</p>
            <div class="flex items-center justify-between">
              <div class="text-xl font-extrabold text-orange-500">${new Intl.NumberFormat('ro-RO').format(car.price)} €</div>
              <span class="text-sm text-orange-500 font-semibold">Vezi →</span>
            </div>
          </div>
        </a>
      </div>
    `).join('');

    document.querySelectorAll('.remove-fav').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = Number((btn as HTMLElement).dataset.id);
        const current: number[] = JSON.parse(localStorage.getItem('dagauto_favorites') || '[]');
        const updated = current.filter(i => i !== id);
        localStorage.setItem('dagauto_favorites', JSON.stringify(updated));
        window.dispatchEvent(new Event('favorites-changed'));
        (btn.closest('.bg-white') as HTMLElement)?.remove();
        if (document.querySelectorAll('#cars-grid > div').length === 0) {
          grid.classList.add('hidden');
          empty.classList.remove('hidden');
        }
      });
    });
  }

  loadFavorites();
</script>
