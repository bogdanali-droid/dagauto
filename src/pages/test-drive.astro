---
import Layout from '../layouts/Layout.astro';

const success = Astro.url.searchParams.get('success');
const masina = Astro.url.searchParams.get('masina') || '';
---

<Layout
  title="Test Drive - DAG Auto Buzău"
  description="Programează un test drive la DAG Auto Buzău. Încearcă mașina înainte să o cumperi. Programare rapidă și gratuită."
>
  <section class="bg-navy-900 text-white py-10" style="background-color: #0f2244;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2">🏎️ Test Drive</h1>
      <p class="text-gray-300">Încearcă mașina înainte să decizi</p>
    </div>
  </section>

  <section class="py-12 bg-gray-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl shadow-md p-8">
        {success === '1' && (
          <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg p-4 mb-6">
            ✅ Solicitarea de test drive a fost trimisă! Te contactăm în curând pentru confirmare.
          </div>
        )}

        <form method="POST" action="/api/submit-form" class="space-y-4">
          <input type="hidden" name="form_type" value="test-drive" />
          <input type="hidden" name="redirect" value="/test-drive?success=1" />

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="form-label">Nume și Prenume *</label>
              <input type="text" name="nume" required class="form-input" />
            </div>
            <div>
              <label class="form-label">Telefon *</label>
              <input type="tel" name="telefon" required class="form-input" placeholder="07xx xxx xxx" />
            </div>
          </div>
          <div>
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-input" />
          </div>
          <div>
            <label class="form-label">Mașina dorită pentru test drive</label>
            <input type="text" name="masina" class="form-input" value={masina} placeholder="ex: BMW X5 2020" />
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="form-label">Data preferată</label>
              <input type="date" name="data" class="form-input" min={new Date().toISOString().split('T')[0]} />
            </div>
            <div>
              <label class="form-label">Ora preferată</label>
              <select name="ora" class="form-select">
                <option>09:00</option>
                <option>10:00</option>
                <option>11:00</option>
                <option>12:00</option>
                <option>13:00</option>
                <option>14:00</option>
                <option>15:00</option>
                <option>16:00</option>
                <option>17:00</option>
              </select>
            </div>
          </div>
          <div>
            <label class="form-label">Observații</label>
            <textarea name="observatii" rows="3" class="form-input resize-none" placeholder="Orice detaliu relevant..."></textarea>
          </div>
          <button type="submit" class="btn-primary w-full text-base py-3">
            🏎️ Programează Test Drive →
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
