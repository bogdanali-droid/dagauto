---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Acasă' },
  { href: '/parc-auto', label: 'Parc Auto' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="bg-navy-900 text-white sticky top-0 z-50 shadow-lg" style="background-color: #0a1a33;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-2xl font-extrabold text-orange-500">DAG</span>
        <span class="text-xl font-bold">Auto</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors hover:text-orange-400 ${
              pathname === link.href ? 'text-orange-400' : 'text-gray-200'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + Phone + Favorites -->
      <div class="hidden md:flex items-center gap-4">
        <a href="tel:0721586534" class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors">
          <svg class="w-4 h-4 text-orange-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          0721 586 534
        </a>
        <a href="/favorite" class="relative p-2 text-gray-300 hover:text-orange-400 transition-colors" aria-label="Favorite">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          <span id="fav-count" class="hidden absolute -top-1 -right-1 bg-orange-500 text-white text-xs font-bold w-4 h-4 rounded-full flex items-center justify-center">0</span>
        </a>
        <a href="/parc-auto" class="btn-primary text-sm py-2 px-4">
          Vezi Mașini
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="menu-btn" class="md:hidden p-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/10 transition-colors" aria-label="Meniu">
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10">
    <nav class="px-4 py-4 space-y-2">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block px-4 py-2 rounded-lg text-sm font-medium transition-colors hover:bg-white/10 ${
            pathname === link.href ? 'text-orange-400 bg-white/10' : 'text-gray-200'
          }`}
        >
          {link.label}
        </a>
      ))}
      <div class="pt-2 border-t border-white/10 space-y-2">
        <a href="tel:0721586534" class="block px-4 py-2 text-sm text-gray-300">📞 0721 586 534</a>
        <a href="/parc-auto" class="btn-primary block text-sm text-center">Vezi Mașini</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    menuIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  });

  // Favorites counter
  function updateFavCount() {
    try {
      const favs = JSON.parse(localStorage.getItem('dagauto_favorites') || '[]');
      const el = document.getElementById('fav-count');
      if (el) {
        el.textContent = String(favs.length);
        el.classList.toggle('hidden', favs.length === 0);
      }
    } catch {}
  }
  updateFavCount();
  window.addEventListener('favorites-changed', updateFavCount);
</script>
