---
import Layout from '../layouts/Layout.astro';

const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
---

<Layout
  title="Contact - DAG Auto Buzău"
  description="Contactează echipa DAG Auto. Suntem disponibili telefonic, prin email sau vizitând parcul nostru auto din Buzău."
>
  <section class="bg-navy-900 text-white py-10" style="background-color: #0f2244;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2">Contact</h1>
      <p class="text-gray-300">Suntem aici să te ajutăm</p>
    </div>
  </section>

  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold text-navy-800" style="color: #0f2244;">Găsește-ne</h2>
          <div class="space-y-4">
            {[
              { icon: '📍', title: 'Adresă', content: 'Calea E85 nr.37\nCom. Mărăcineni, Buzău' },
              { icon: '📞', title: 'Telefon', content: '0721 586 534', href: 'tel:0721586534' },
              { icon: '✉️', title: 'Email', content: 'contact@dagauto.ro', href: 'mailto:contact@dagauto.ro' },
              { icon: '🕐', title: 'Program', content: 'Luni–Vineri: 9:00–18:00\nSâmbătă: 9:00–15:00\nDuminică: Închis' },
            ].map(item => (
              <div class="flex items-start gap-4 bg-white p-4 rounded-xl shadow-sm">
                <span class="text-2xl">{item.icon}</span>
                <div>
                  <p class="font-semibold text-gray-900 mb-1">{item.title}</p>
                  {item.href ? (
                    <a href={item.href} class="text-orange-600 hover:underline whitespace-pre-line">{item.content}</a>
                  ) : (
                    <p class="text-gray-600 whitespace-pre-line">{item.content}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-white rounded-xl shadow-md p-8">
          <h2 class="text-2xl font-bold text-navy-800 mb-6" style="color: #0f2244;">Trimite Mesaj</h2>

          {success === '1' && (
            <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg p-4 mb-6">
              ✅ Mesajul tău a fost trimis cu succes! Te vom contacta în curând.
            </div>
          )}
          {error && (
            <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg p-4 mb-6">
              ❌ A apărut o eroare. Te rugăm să încerci din nou.
            </div>
          )}

          <form method="POST" action="/api/submit-form" class="space-y-4">
            <input type="hidden" name="form_type" value="contact" />
            <input type="hidden" name="redirect" value="/contact?success=1" />

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="form-label">Nume *</label>
                <input type="text" name="nume" required class="form-input" placeholder="Numele tău" />
              </div>
              <div>
                <label class="form-label">Prenume</label>
                <input type="text" name="prenume" class="form-input" placeholder="Prenumele tău" />
              </div>
            </div>
            <div>
              <label class="form-label">Email *</label>
              <input type="email" name="email" required class="form-input" placeholder="email@exemplu.ro" />
            </div>
            <div>
              <label class="form-label">Telefon</label>
              <input type="tel" name="telefon" class="form-input" placeholder="07xx xxx xxx" />
            </div>
            <div>
              <label class="form-label">Mesaj *</label>
              <textarea name="mesaj" required rows="5" class="form-input resize-none" placeholder="Cum te putem ajuta?"></textarea>
            </div>
            <div class="flex items-start gap-2 text-sm text-gray-600">
              <input type="checkbox" required id="gdpr" class="mt-1" />
              <label for="gdpr">Sunt de acord cu <a href="#" class="text-orange-500 underline">politica de confidențialitate</a> *</label>
            </div>
            <button type="submit" class="btn-primary w-full text-base py-3">
              Trimite Mesajul →
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
