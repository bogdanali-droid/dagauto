---
import Layout from '../../layouts/Layout.astro';
import CarCard from '../../components/CarCard.astro';
import { getCarBySlug, getCarImages, getCars } from '../../lib/db';

const { slug } = Astro.params;
const DB = Astro.locals.runtime?.env?.DB;
if (!DB) return Astro.redirect('/parc-auto');

const car = await getCarBySlug(DB, slug!);
if (!car) return Astro.redirect('/parc-auto');

const imagesResult = await getCarImages(DB, car.id);
const images = imagesResult.results;
const primaryImage = images.find(img => img.is_primary) || images[0];

// Similar cars (same make, different car)
let similarCars: any[] = [];
try {
  const sim = await getCars(DB, { make: car.make, limit: 4 });
  similarCars = sim.results.filter((c: any) => c.id !== car.id).slice(0, 3);
} catch {}

const features = car.features ? car.features.split(',').map(f => f.trim()).filter(Boolean) : [];
const formattedPrice = new Intl.NumberFormat('ro-RO').format(car.price);
const formattedMileage = new Intl.NumberFormat('ro-RO').format(car.mileage);
const hasDiscount = (car as any).old_price && (car as any).old_price > car.price;
const discountPct = hasDiscount ? Math.round((1 - car.price / (car as any).old_price) * 100) : 0;

const specIcons: Record<string, string> = {
  'An fabricație': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>`,
  'Kilometraj': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z"/><path d="M7 13.5C7 11 9.2 9 12 9s5 2 5 4.5"/><path d="M12 9v0M8.5 11.5l2.5 1.5"/><circle cx="12" cy="14" r="1" fill="currentColor" stroke="none"/></svg>`,
  'Combustibil': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"/><path d="M3 22h12"/><path d="M9 22v-6"/><path d="M15 8h2a2 2 0 0 1 2 2v6a2 2 0 0 0 2 2v0a2 2 0 0 0 2-2V9l-3-3"/><path d="M18 5l2 2"/></svg>`,
  'Transmisie': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><path d="M5 8v3a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V8"/><path d="M12 12v4"/></svg>`,
  'Caroserie': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17H4a2 2 0 0 1-2-2v-3l2-5h12l2 5v3a2 2 0 0 1-2 2h-3"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="16.5" cy="17.5" r="2.5"/><path d="M6 9h12"/></svg>`,
  'Culoare': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 22a7 7 0 1 1 0-14"/></svg>`,
  'Motor': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><path d="M6 12h4m4 0h4M8 12v4m8-4v4"/></svg>`,
  'Putere': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
};

const carExtra = car as any;

const specs = [
  { label: 'An fabricație', value: String(car.year) },
  { label: 'Kilometraj', value: `${formattedMileage} km` },
  { label: 'Combustibil', value: car.fuel_type },
  { label: 'Transmisie', value: car.transmission },
  { label: 'Caroserie', value: car.body_type },
  { label: 'Culoare', value: car.color },
  { label: 'Motor', value: car.engine_size },
  { label: 'Putere', value: car.power ? `${car.power} CP` : '-' },
  { label: 'Tracțiune', value: carExtra.drivetrain || '' },
  { label: 'Nr. uși', value: carExtra.doors ? String(carExtra.doors) : '' },
  { label: 'Nr. locuri', value: carExtra.seats ? String(carExtra.seats) : '' },
  { label: 'Normă Euro', value: carExtra.euro_standard || '' },
  { label: 'Proprietari anteriori', value: carExtra.nr_owners ? String(carExtra.nr_owners) : '' },
  { label: 'Țara origine', value: carExtra.country_origin || '' },
].filter(s => s.value && s.value !== '-' && s.value !== '0 CP');

// Schema.org Car structured data
const schemaCar = {
  "@context": "https://schema.org",
  "@type": "Car",
  "name": car.title,
  "brand": { "@type": "Brand", "name": car.make },
  "model": car.model,
  "modelDate": String(car.year),
  "mileageFromOdometer": { "@type": "QuantitativeValue", "value": car.mileage, "unitCode": "KMT" },
  "fuelType": car.fuel_type,
  "vehicleTransmission": car.transmission,
  "bodyType": car.body_type,
  "color": car.color || undefined,
  "vehicleEngine": car.engine_size ? { "@type": "EngineSpecification", "engineDisplacement": car.engine_size } : undefined,
  "offers": {
    "@type": "Offer",
    "price": car.price,
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "AutoDealer", "name": "DAG Auto Buzău" }
  },
  "image": primaryImage?.image_url,
  "description": car.description,
  "url": `https://dagauto.ro/parc-auto/${car.slug}`
};
---

<Layout
  title={`${car.title} - ${car.year} | DAG Auto Buzău`}
  description={`${car.title}, ${car.year}, ${formattedMileage} km, ${car.fuel_type}. Preț: ${formattedPrice} €. Disponibil la DAG Auto Buzău.`}
  image={primaryImage?.image_url}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaCar)} slot="head" />
  <!-- Breadcrumb -->
  <section class="bg-navy-900 text-white py-4" style="background-color: #0f2244;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-400 flex items-center gap-2 flex-wrap">
        <a href="/" class="hover:text-orange-400">Acasă</a>
        <span>/</span>
        <a href="/parc-auto" class="hover:text-orange-400">Parc Auto</a>
        <span>/</span>
        <span class="text-gray-200">{car.title}</span>
      </nav>
    </div>
  </section>

  <section class="py-8 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-8">

        <!-- LEFT: Images + Info -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Image gallery -->
          <div class="bg-white rounded-xl overflow-hidden shadow-md">
            {primaryImage ? (
              <img
                id="main-image"
                src={primaryImage.image_url}
                alt={car.title}
                class="w-full object-cover max-h-[480px] cursor-zoom-in"
                loading="eager"
              />
            ) : (
              <div class="w-full h-64 bg-gray-100 flex items-center justify-center text-gray-400">
                <span class="text-6xl">🚗</span>
              </div>
            )}
          </div>

          {images.length > 1 && (
            <div class="grid grid-cols-4 sm:grid-cols-6 gap-2">
              {images.map((img, i) => (
                <img
                  src={img.image_url}
                  alt={`${car.title} foto ${i + 1}`}
                  class="w-full aspect-square object-cover rounded-lg cursor-pointer hover:opacity-80 transition-opacity shadow-sm border-2 border-transparent hover:border-orange-400"
                  loading="lazy"
                  data-src={img.image_url}
                  onclick="document.getElementById('main-image').src=this.dataset.src"
                />
              ))}
            </div>
          )}

          <!-- Trust badges -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {[
              { icon: '🛡️', label: 'Garanție 12 luni' },
              { icon: '🔍', label: 'Verificat tehnic' },
              { icon: '📋', label: 'Istoric complet' },
              { icon: '💳', label: 'Finanțare rapidă' },
            ].map(b => (
              <div class="bg-white rounded-xl p-3 text-center shadow-sm border border-gray-100">
                <div class="text-2xl mb-1">{b.icon}</div>
                <div class="text-xs font-semibold text-gray-700">{b.label}</div>
              </div>
            ))}
          </div>

          <!-- Stare vehicul badges -->
          <div class="flex flex-wrap gap-3">
            {carExtra.accident_free !== 0 && (
              <div class="flex items-center gap-2 bg-green-50 border border-green-200 rounded-lg px-4 py-2.5">
                <span class="text-green-600 font-bold text-lg">✓</span>
                <div>
                  <div class="text-xs text-green-700 font-bold">Fără accident</div>
                  <div class="text-xs text-green-600">în istoric</div>
                </div>
              </div>
            )}
            {carExtra.service_history === 1 && (
              <div class="flex items-center gap-2 bg-blue-50 border border-blue-200 rounded-lg px-4 py-2.5">
                <span class="text-blue-600 font-bold text-lg">📋</span>
                <div>
                  <div class="text-xs text-blue-700 font-bold">Istoric service</div>
                  <div class="text-xs text-blue-600">disponibil</div>
                </div>
              </div>
            )}
            {carExtra.nr_owners > 0 && (
              <div class="flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-lg px-4 py-2.5">
                <span class="text-gray-600 font-bold text-lg">👤</span>
                <div>
                  <div class="text-xs text-gray-700 font-bold">{carExtra.nr_owners} {carExtra.nr_owners === 1 ? 'proprietar' : 'proprietari'}</div>
                  <div class="text-xs text-gray-500">anteriori</div>
                </div>
              </div>
            )}
            {carExtra.country_origin && (
              <div class="flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-lg px-4 py-2.5">
                <span class="text-gray-600 font-bold text-lg">🌍</span>
                <div>
                  <div class="text-xs text-gray-700 font-bold">Import</div>
                  <div class="text-xs text-gray-500">{carExtra.country_origin}</div>
                </div>
              </div>
            )}
          </div>

          <!-- carVertical History Check -->
          <div class="bg-gradient-to-r from-slate-800 to-slate-900 rounded-xl p-5 text-white">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0 text-2xl">🔎</div>
              <div class="flex-1">
                <div class="font-bold text-base mb-1">Verifică istoricul mașinii</div>
                <p class="text-sm text-gray-300 mb-3">
                  Raportul carVertical îți arată istoricul complet: kilometraj real, accidente, proveniență, furturi, ITP-uri anterioare.
                </p>
                <div class="flex flex-wrap gap-2 mb-4 text-xs">
                  {['✓ Kilometraj verificat', '✓ Istoric accidente', '✓ Verificare furturi', '✓ Origine vehicul'].map(t => (
                    <span class="bg-white/10 px-2 py-1 rounded-full">{t}</span>
                  ))}
                </div>
                <a
                  href={`https://www.carvertical.com/ro/verificare?vin=${carExtra.vin || ''}&utm_source=dagauto`}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-semibold px-4 py-2.5 rounded-lg transition-colors text-sm"
                >
                  Verifică cu carVertical →
                </a>
                <div class="text-xs text-gray-400 mt-2">Raport disponibil în ~40 secunde · de la 12,99 €</div>
              </div>
            </div>
          </div>

          <!-- Description -->
          {car.description && (
            <div class="bg-white rounded-xl shadow-md p-6">
              <h2 class="text-xl font-bold mb-4" style="color: #0f2244;">Descriere</h2>
              <p class="text-gray-700 leading-relaxed whitespace-pre-wrap">{car.description}</p>
            </div>
          )}

          <!-- Features/Dotări -->
          {features.length > 0 && (
            <div class="bg-white rounded-xl shadow-md p-6">
              <h2 class="text-xl font-bold mb-4" style="color: #0f2244;">Dotări</h2>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                {features.map(f => (
                  <div class="flex items-center gap-2 text-sm text-gray-700">
                    <span class="text-green-500 font-bold">✓</span>
                    <span>{f}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Calculator Finanțare -->
          <div class="bg-white rounded-xl shadow-md p-6" id="calculator">
            <h2 class="text-xl font-bold mb-2" style="color: #0f2244;">💳 Calculator Finanțare</h2>
            <p class="text-sm text-gray-500 mb-6">Estimează rata lunară pentru această mașină</p>

            <div class="space-y-5">
              <div>
                <label class="form-label">Preț vehicul</label>
                <div class="text-2xl font-bold text-orange-500">{formattedPrice} €</div>
              </div>

              <div>
                <label class="form-label flex justify-between">
                  <span>Avans</span>
                  <span class="text-orange-500 font-semibold" id="avans-val">20%</span>
                </label>
                <input type="range" id="avans-range" min="10" max="70" value="20" step="5"
                  class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-orange-500" />
                <div class="flex justify-between text-xs text-gray-400 mt-1">
                  <span>10%</span><span>70%</span>
                </div>
              </div>

              <div>
                <label class="form-label flex justify-between">
                  <span>Perioadă</span>
                  <span class="text-orange-500 font-semibold" id="period-val">48 luni</span>
                </label>
                <input type="range" id="period-range" min="12" max="84" value="48" step="12"
                  class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-orange-500" />
                <div class="flex justify-between text-xs text-gray-400 mt-1">
                  <span>12 luni</span><span>84 luni</span>
                </div>
              </div>

              <div class="bg-orange-50 border border-orange-200 rounded-xl p-5 text-center">
                <div class="text-sm text-gray-600 mb-1">Rată lunară estimată</div>
                <div class="text-4xl font-extrabold text-orange-500" id="rata-result">—</div>
                <div class="text-xs text-gray-500 mt-2" id="calc-details"></div>
              </div>

              <div class="text-xs text-gray-400 bg-gray-50 rounded-lg p-3">
                * Calculul este orientativ (dobândă 8,5% / an). Rata finală depinde de banca finanțatoare. Avans minim 10%.
              </div>

              <a href={`/cerere-finantare?masina=${encodeURIComponent(car.title)}`}
                class="btn-primary w-full text-center block">
                Solicită Finanțare Acum →
              </a>

              <!-- BT + TBI + MOGO Calculator CTAs -->
              <div class="grid grid-cols-1 gap-2">
                <a
                  href="https://www.bancatransilvania.ro/persoane-fizice/credite/credite-auto/"
                  target="_blank" rel="noopener"
                  class="flex items-center gap-3 p-3 rounded-xl border-2 border-slate-800 hover:bg-slate-800 hover:text-white transition-all group"
                  style="color: #0f2244;"
                >
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 bg-slate-800">
                    <span class="text-white font-black text-xs" style="font-family:'Arial Black',sans-serif;letter-spacing:-0.5px;">BT</span>
                  </div>
                  <div>
                    <div class="font-bold text-sm">Calculator Banca Transilvania</div>
                    <div class="text-xs opacity-50">Credit auto · rate fixe →</div>
                  </div>
                </a>
                <a
                  href="https://www.tbi.ro/credite/credit-auto/"
                  target="_blank" rel="noopener"
                  class="flex items-center gap-3 p-3 rounded-xl border-2 border-blue-700 hover:bg-blue-700 hover:text-white transition-all group"
                  style="color: #1d4ed8;"
                >
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 bg-blue-700">
                    <span class="text-white font-black text-xs" style="font-family:'Arial Black',sans-serif;letter-spacing:-0.5px;">TBI</span>
                  </div>
                  <div>
                    <div class="font-bold text-sm">Calculator TBI Bank</div>
                    <div class="text-xs opacity-50">Aprobare rapidă · avans minim →</div>
                  </div>
                </a>
                <a
                  href="https://www.mogo.ro/aplica"
                  target="_blank" rel="noopener"
                  class="flex items-center gap-3 p-3 rounded-xl border-2 border-green-600 hover:bg-green-600 hover:text-white transition-all group"
                  style="color: #16a34a;"
                >
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 bg-green-600">
                    <span class="text-white font-black text-xs" style="font-family:'Arial Black',sans-serif;letter-spacing:-0.5px;">MOGO</span>
                  </div>
                  <div>
                    <div class="font-bold text-sm">Leasing MOGO</div>
                    <div class="text-xs opacity-50">Fără avans · fără venituri dovedite →</div>
                  </div>
                </a>
              </div>
            </div>
          </div>

          <!-- Specs table -->
          <div class="bg-white rounded-xl shadow-md p-6">
            <h2 class="text-xl font-bold mb-4" style="color: #0f2244;">Specificații tehnice</h2>
            <div class="grid grid-cols-2 gap-3">
              {specs.map(s => (
                <div class="flex items-center gap-3 border border-gray-100 rounded-lg p-3">
                  <div class="w-9 h-9 flex-shrink-0 flex items-center justify-center rounded-lg bg-slate-50 text-slate-600" style="color:#1e3a5f;" set:html={specIcons[s.label] || ''} />
                  <div>
                    <div class="text-xs text-gray-400 font-medium uppercase tracking-wide" style="font-size:10px;">{s.label}</div>
                    <div class="font-semibold text-gray-900 text-sm mt-0.5">{s.value}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- RIGHT: Sidebar -->
        <div class="space-y-6">
          <div class="bg-white rounded-xl shadow-md p-6 sticky top-20">
            <!-- Title + Price -->
            <h1 class="text-xl font-bold text-gray-900 mb-1">{car.title}</h1>
            <p class="text-gray-500 text-sm mb-4">{car.year} · {formattedMileage} km · {car.fuel_type}</p>

            {hasDiscount && (
              <div class="flex items-center gap-2 mb-1">
                <span class="bg-red-100 text-red-600 text-xs font-bold px-2 py-1 rounded-full">-{discountPct}% REDUCERE</span>
                <span class="text-gray-400 line-through text-sm">{new Intl.NumberFormat('ro-RO').format((car as any).old_price)} €</span>
              </div>
            )}
            <div class="text-4xl font-extrabold text-orange-500 mb-2">
              {formattedPrice} <span class="text-xl">€</span>
            </div>
            <div class="text-xs text-gray-400 mb-5">≈ {new Intl.NumberFormat('ro-RO').format(Math.round(car.price * 4.97))} lei · TVA inclus</div>

            <!-- CTAs -->
            <div class="space-y-2.5 mb-5">
              <a href={`/test-drive?masina=${encodeURIComponent(car.title)}`}
                class="btn-primary w-full text-center block">
                🏎️ Solicită Test Drive
              </a>
              <a href="#calculator"
                class="btn-secondary w-full text-center block">
                💳 Calculează Rata
              </a>
              <div class="grid grid-cols-3 gap-2">
                <a
                  href="https://www.bancatransilvania.ro/persoane-fizice/credite/credite-auto/"
                  target="_blank"
                  rel="noopener"
                  class="flex flex-col items-center justify-center gap-1 py-2.5 px-2 rounded-lg font-bold text-xs transition-colors border-2 border-slate-800 hover:bg-slate-800 hover:text-white text-slate-800 bg-white"
                >
                  <span class="font-black text-sm" style="letter-spacing:-0.5px; font-family:'Arial Black',sans-serif;">BT</span>
                  <span>Rate BT</span>
                </a>
                <a
                  href="https://www.tbi.ro/credite/credit-auto/"
                  target="_blank"
                  rel="noopener"
                  class="flex flex-col items-center justify-center gap-1 py-2.5 px-2 rounded-lg font-bold text-xs transition-colors border-2 border-blue-700 hover:bg-blue-700 hover:text-white text-blue-700 bg-white"
                >
                  <span class="font-black text-sm" style="letter-spacing:-0.5px; font-family:'Arial Black',sans-serif;">TBI</span>
                  <span>Rate TBI</span>
                </a>
                <a
                  href="https://www.mogo.ro/aplica"
                  target="_blank"
                  rel="noopener"
                  class="flex flex-col items-center justify-center gap-1 py-2.5 px-2 rounded-lg font-bold text-xs transition-colors border-2 border-green-600 hover:bg-green-600 hover:text-white text-green-700 bg-white"
                >
                  <span class="font-black text-sm" style="letter-spacing:-0.5px; font-family:'Arial Black',sans-serif;">MOGO</span>
                  <span>Leasing</span>
                </a>
              </div>
              <a href={`/programeaza-vizita?masina=${encodeURIComponent(car.title)}`}
                class="btn-outline w-full text-center block">
                📅 Programează Vizită
              </a>
              <!-- WhatsApp -->
              <a href={`https://wa.me/40721586534?text=${encodeURIComponent(`Bună ziua! Sunt interesat de ${car.title} (${car.year}, ${formattedPrice} €). Puteți să îmi dați mai multe detalii?`)}`}
                target="_blank" rel="noopener"
                class="flex items-center justify-center gap-2 w-full py-3 px-4 bg-green-500 hover:bg-green-600 text-white font-semibold rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
