---
import Layout from '../../layouts/Layout.astro';
import { getCarBySlug, getCarImages } from '../../lib/db';

const { slug } = Astro.params;
const DB = Astro.locals.runtime?.env?.DB;
if (!DB) return Astro.redirect('/parc-auto');

const car = await getCarBySlug(DB, slug!);
if (!car) return Astro.redirect('/parc-auto');

const imagesResult = await getCarImages(DB, car.id);
const images = imagesResult.results;
const primaryImage = images.find(img => img.is_primary) || images[0];

const features = car.features ? car.features.split(',').map(f => f.trim()).filter(Boolean) : [];
const formattedPrice = new Intl.NumberFormat('ro-RO').format(car.price);
const formattedMileage = new Intl.NumberFormat('ro-RO').format(car.mileage);

const specs = [
  { label: 'An fabricație', value: String(car.year), icon: '📅' },
  { label: 'Kilometraj', value: `${formattedMileage} km`, icon: '🛣️' },
  { label: 'Combustibil', value: car.fuel_type, icon: '⛽' },
  { label: 'Transmisie', value: car.transmission, icon: '⚙️' },
  { label: 'Caroserie', value: car.body_type, icon: '🚗' },
  { label: 'Culoare', value: car.color, icon: '🎨' },
  { label: 'Motor', value: car.engine_size, icon: '🔧' },
  { label: 'Putere', value: `${car.power} CP`, icon: '⚡' },
];
---

<Layout
  title={`${car.title} - ${car.year} | DAG Auto Buzău`}
  description={`${car.title}, ${car.year}, ${formattedMileage} km, ${car.fuel_type}. Preț: ${formattedPrice} €. Disponibil la DAG Auto Buzău.`}
  image={primaryImage?.image_url}
>
  <section class="bg-navy-900 text-white py-6" style="background-color: #0f2244;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-400">
        <a href="/" class="hover:text-orange-400">Acasă</a>
        <span class="mx-2">/</span>
        <a href="/parc-auto" class="hover:text-orange-400">Parc Auto</a>
        <span class="mx-2">/</span>
        <span class="text-gray-200">{car.title}</span>
      </nav>
    </div>
  </section>

  <section class="py-10 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Images + Description -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Main image -->
          <div class="bg-white rounded-xl overflow-hidden shadow-md">
            {primaryImage ? (
              <img
                src={primaryImage.image_url}
                alt={car.title}
                class="w-full object-cover max-h-96"
                loading="eager"
              />
            ) : (
              <div class="w-full h-64 bg-gray-100 flex items-center justify-center text-gray-400">
                <span class="text-6xl">🚗</span>
              </div>
            )}
          </div>

          <!-- Thumbnails -->
          {images.length > 1 && (
            <div class="grid grid-cols-4 sm:grid-cols-6 gap-2">
              {images.map(img => (
                <img
                  src={img.image_url}
                  alt={car.title}
                  class="w-full aspect-square object-cover rounded-lg cursor-pointer hover:opacity-80 transition-opacity shadow-sm"
                  loading="lazy"
                />
              ))}
            </div>
          )}

          <!-- Description -->
          <div class="bg-white rounded-xl shadow-md p-6">
            <h2 class="text-xl font-bold text-navy-800 mb-4" style="color: #0f2244;">Descriere</h2>
            <p class="text-gray-700 leading-relaxed whitespace-pre-wrap">{car.description || 'Contactați-ne pentru detalii suplimentare.'}</p>
          </div>

          <!-- Features -->
          {features.length > 0 && (
            <div class="bg-white rounded-xl shadow-md p-6">
              <h2 class="text-xl font-bold text-navy-800 mb-4" style="color: #0f2244;">Dotări</h2>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                {features.map(f => (
                  <div class="flex items-center gap-2 text-sm text-gray-700">
                    <span class="text-orange-500 font-bold">✓</span>
                    <span>{f}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Price card -->
          <div class="bg-white rounded-xl shadow-md p-6 sticky top-20">
            <h1 class="text-2xl font-bold text-gray-900 mb-1">{car.title}</h1>
            <p class="text-gray-500 text-sm mb-4">{car.year} · {formattedMileage} km · {car.fuel_type}</p>

            <div class="text-4xl font-extrabold text-orange-500 mb-6">
              {formattedPrice} <span class="text-2xl">€</span>
            </div>

            <div class="space-y-3 mb-6">
              <a href={`/test-drive?masina=${encodeURIComponent(car.title)}`} class="btn-primary w-full text-center block">
                🏎️ Solicită Test Drive
              </a>
              <a href={`/cerere-finantare?masina=${encodeURIComponent(car.title)}`} class="btn-secondary w-full text-center block">
                💳 Cerere Finanțare
              </a>
              <a href={`/programeaza-vizita?masina=${encodeURIComponent(car.title)}`} class="btn-outline w-full text-center block">
                📅 Programează Vizită
              </a>
            </div>

            <div class="border-t pt-4 space-y-2 text-sm">
              <a href="tel:0721586534" class="flex items-center gap-2 text-gray-700 hover:text-orange-500 transition-colors">
                <span>📞</span> <span>0721 586 534</span>
              </a>
              <a href="mailto:contact@dagauto.ro" class="flex items-center gap-2 text-gray-700 hover:text-orange-500 transition-colors">
                <span>✉️</span> <span>contact@dagauto.ro</span>
              </a>
            </div>
          </div>

          <!-- Specs -->
          <div class="bg-white rounded-xl shadow-md p-6">
            <h2 class="text-lg font-bold text-navy-800 mb-4" style="color: #0f2244;">Specificații</h2>
            <div class="space-y-3">
              {specs.map(s => (
                <div class="flex items-center justify-between text-sm border-b border-gray-50 pb-2">
                  <span class="flex items-center gap-2 text-gray-500">
                    <span>{s.icon}</span> {s.label}
                  </span>
                  <span class="font-semibold text-gray-800">{s.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
