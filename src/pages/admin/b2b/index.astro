---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSessionToken, verifySessionToken } from '../../../lib/auth';

const DB = Astro.locals.runtime?.env?.DB;
const secret = Astro.locals.runtime?.env?.SESSION_SECRET || 'dev-secret-change-in-prod';
const token = getSessionToken(Astro.request);
const adminId = token ? await verifySessionToken(token, secret) : null;
if (!adminId) return Astro.redirect('/admin/login');

// Handle approve/suspend actions
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action') as string;
  const userId = data.get('user_id') as string;
  const carId = data.get('car_id') as string;

  if (action === 'approve_user' && userId && DB) {
    await DB.prepare("UPDATE b2b_users SET status = 'approved' WHERE id = ?").bind(parseInt(userId)).run();
  } else if (action === 'suspend_user' && userId && DB) {
    await DB.prepare("UPDATE b2b_users SET status = 'suspended' WHERE id = ?").bind(parseInt(userId)).run();
  } else if (action === 'approve_car' && carId && DB) {
    await DB.prepare("UPDATE cars SET status = 'available' WHERE id = ?").bind(parseInt(carId)).run();
  } else if (action === 'reject_car' && carId && DB) {
    await DB.prepare("UPDATE cars SET status = 'rejected' WHERE id = ?").bind(parseInt(carId)).run();
  }
  return Astro.redirect('/admin/b2b');
}

// Load data
const usersResult = await DB?.prepare(
  'SELECT * FROM b2b_users ORDER BY created_at DESC'
).all();
const users = (usersResult?.results || []) as any[];

const carsResult = await DB?.prepare(`
  SELECT c.id, c.title, c.price, c.original_price, c.markup_pct, c.status, c.slug, c.created_at,
         u.name as owner_name, u.email as owner_email, u.phone as owner_phone,
         ci.image_url as primary_image
  FROM cars c
  JOIN b2b_users u ON u.id = c.b2b_user_id
  LEFT JOIN car_images ci ON ci.car_id = c.id AND ci.is_primary = 1
  ORDER BY c.id DESC
`).all();
const b2bCars = (carsResult?.results || []) as any[];
---

<AdminLayout title="B2B Management">
  <div class="p-6 max-w-6xl mx-auto space-y-8">
    <h1 class="text-2xl font-bold text-gray-800">B2B Management</h1>

    <!-- Users -->
    <div>
      <h2 class="text-lg font-bold text-gray-700 mb-4">Conturi B2B ({users.length})</h2>
      <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
        {users.length === 0 ? (
          <p class="text-center text-gray-400 py-8">Niciun cont B2B înregistrat</p>
        ) : (
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b">
              <tr>
                <th class="text-left px-5 py-3 font-semibold text-gray-600">Utilizator</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-600">Contact</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-600">Firmă</th>
                <th class="text-center px-4 py-3 font-semibold text-gray-600">Status</th>
                <th class="text-center px-4 py-3 font-semibold text-gray-600">Data</th>
                <th class="px-4 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              {users.map((u: any) => (
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3 font-semibold text-gray-800">{u.name}</td>
                  <td class="px-4 py-3 text-gray-500">
                    <div>{u.email}</div>
                    <div class="text-xs">{u.phone}</div>
                  </td>
                  <td class="px-4 py-3 text-gray-500">{u.company || '—'}</td>
                  <td class="px-4 py-3 text-center">
                    <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold ${
                      u.status === 'approved' ? 'bg-green-100 text-green-700' :
                      u.status === 'suspended' ? 'bg-red-100 text-red-700' :
                      'bg-yellow-100 text-yellow-700'
                    }`}>{u.status}</span>
                  </td>
                  <td class="px-4 py-3 text-center text-gray-400 text-xs">{u.created_at?.slice(0,10)}</td>
                  <td class="px-4 py-3">
                    <form method="POST" class="flex gap-2">
                      <input type="hidden" name="user_id" value={u.id} />
                      {u.status !== 'approved' && (
                        <button name="action" value="approve_user"
                          class="text-xs bg-green-500 hover:bg-green-600 text-white px-3 py-1 rounded-lg font-semibold">
                          Aprobă
                        </button>
                      )}
                      {u.status === 'approved' && (
                        <button name="action" value="suspend_user"
                          class="text-xs bg-red-100 hover:bg-red-200 text-red-700 px-3 py-1 rounded-lg font-semibold">
                          Suspendă
                        </button>
                      )}
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>

    <!-- B2B Cars -->
    <div>
      <h2 class="text-lg font-bold text-gray-700 mb-4">Mașini B2B ({b2bCars.length})</h2>
      <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
        {b2bCars.length === 0 ? (
          <p class="text-center text-gray-400 py-8">Nicio mașină B2B</p>
        ) : (
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b">
              <tr>
                <th class="text-left px-5 py-3 font-semibold text-gray-600">Mașină</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-600">Proprietar</th>
                <th class="text-right px-4 py-3 font-semibold text-gray-600">Preț owner</th>
                <th class="text-right px-4 py-3 font-semibold text-gray-600">Preț afișat</th>
                <th class="text-center px-4 py-3 font-semibold text-gray-600">Status</th>
                <th class="px-4 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              {b2bCars.map((car: any) => (
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3">
                    <div class="flex items-center gap-3">
                      {car.primary_image ? (
                        <img src={car.primary_image} alt={car.title} class="w-12 h-9 object-cover rounded" />
                      ) : (
                        <div class="w-12 h-9 bg-gray-100 rounded flex items-center justify-center text-gray-300 text-lg">🚗</div>
                      )}
                      <div>
                        <div class="font-semibold text-gray-800">{car.title}</div>
                        <div class="text-xs text-gray-400">{car.created_at?.slice(0,10)}</div>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-700">{car.owner_name}</div>
                    <div class="text-xs text-gray-400">{car.owner_phone}</div>
                  </td>
                  <td class="px-4 py-3 text-right text-gray-500">{car.original_price ? `${car.original_price.toLocaleString('ro-RO')} €` : '—'}</td>
                  <td class="px-4 py-3 text-right font-bold text-gray-800">{car.price ? `${car.price.toLocaleString('ro-RO')} €` : '—'}</td>
                  <td class="px-4 py-3 text-center">
                    <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold ${
                      car.status === 'available' ? 'bg-green-100 text-green-700' :
                      car.status === 'pending' ? 'bg-yellow-100 text-yellow-700' :
                      car.status === 'sold' ? 'bg-blue-100 text-blue-700' :
                      'bg-red-100 text-red-700'
                    }`}>{car.status}</span>
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex gap-2 items-center">
                      {car.status === 'pending' && (
                        <form method="POST" class="flex gap-2">
                          <input type="hidden" name="car_id" value={car.id} />
                          <button name="action" value="approve_car"
                            class="text-xs bg-green-500 hover:bg-green-600 text-white px-3 py-1 rounded-lg font-semibold">
                            Activează
                          </button>
                          <button name="action" value="reject_car"
                            class="text-xs bg-red-100 hover:bg-red-200 text-red-700 px-3 py-1 rounded-lg font-semibold">
                            Respinge
                          </button>
                        </form>
                      )}
                      <a href={`/parc-auto/${car.slug}`} target="_blank"
                        class="text-xs text-orange-500 hover:underline font-semibold">
                        Vezi →
                      </a>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>
  </div>
</AdminLayout>
