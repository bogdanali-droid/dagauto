---
import B2BLayout from '../../layouts/B2BLayout.astro';
import { getB2BUser } from '../../lib/b2b-auth';

const DB = Astro.locals.runtime?.env?.DB;
const IMAGES = Astro.locals.runtime?.env?.IMAGES;
const secret = Astro.locals.runtime?.env?.SESSION_SECRET || 'dev-secret-change-in-prod';
const user = DB ? await getB2BUser(Astro.request, DB, secret) : null;

if (!user) return Astro.redirect('/b2b/login');
if (user.status !== 'approved') return Astro.redirect('/b2b/dashboard');

let error = '';
let success = false;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const title = data.get('title') as string;
  const make = data.get('make') as string;
  const model = data.get('model') as string;
  const year = parseInt(data.get('year') as string);
  const mileage = parseInt(data.get('mileage') as string);
  const fuel_type = data.get('fuel_type') as string;
  const transmission = data.get('transmission') as string;
  const body_type = data.get('body_type') as string;
  const color = data.get('color') as string;
  const engine_size = data.get('engine_size') as string;
  const power = parseInt(data.get('power') as string) || 0;
  const originalPrice = parseInt(data.get('original_price') as string);
  const description = data.get('description') as string;
  const markup = 15;
  const displayPrice = Math.round(originalPrice * (1 + markup / 100));

  if (!title || !make || !model || !year || !originalPrice) {
    error = 'Completează toate câmpurile obligatorii.';
  } else {
    // Generate slug
    const slug = `${make}-${model}-${year}-${Date.now()}`.toLowerCase()
      .replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-');

    const result = await DB.prepare(`
      INSERT INTO cars (title, slug, make, model, year, price, original_price, markup_pct,
        mileage, fuel_type, transmission, body_type, color, engine_size, power,
        description, status, b2b_user_id, created_at, updated_at)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?, datetime('now'), datetime('now'))
    `).bind(
      title, slug, make, model, year, displayPrice, originalPrice, markup,
      mileage, fuel_type, transmission, body_type, color, engine_size, power,
      description, user.id
    ).run();

    const carId = result.meta?.last_row_id;

    // Upload images
    const imageFiles = data.getAll('images') as File[];
    let isPrimary = 1;
    for (const file of imageFiles) {
      if (!file.size) continue;
      const filename = `${Date.now()}-${file.name.replace(/[^a-z0-9.]/gi, '_')}`;
      const r2Key = `cars/${carId}/${filename}`;
      const ab = await file.arrayBuffer();
      await IMAGES?.put(r2Key, ab, { httpMetadata: { contentType: file.type || 'image/jpeg' } });
      await DB.prepare(
        'INSERT INTO car_images (car_id, image_url, is_primary, sort_order) VALUES (?, ?, ?, ?)'
      ).bind(carId, `/images/${r2Key}`, isPrimary, isPrimary ? 0 : 1).run();
      isPrimary = 0;
    }

    success = true;
  }
}

const currentYear = new Date().getFullYear();
---

<B2BLayout title="Adaugă Mașină">
  <div class="max-w-2xl mx-auto px-4 py-10">
    <div class="flex items-center gap-3 mb-8">
      <a href="/b2b/dashboard" class="text-gray-400 hover:text-gray-600">← Dashboard</a>
      <span class="text-gray-300">/</span>
      <h1 class="text-2xl font-extrabold text-gray-800">Adaugă Mașină</h1>
    </div>

    {success ? (
      <div class="bg-green-50 border border-green-200 rounded-2xl p-10 text-center">
        <div class="text-5xl mb-4">✅</div>
        <h2 class="text-xl font-bold text-green-700 mb-2">Mașina a fost adăugată!</h2>
        <p class="text-green-600 mb-6">Echipa DAG Auto va verifica anunțul și îl va activa în curând.</p>
        <div class="flex gap-3 justify-center">
          <a href="/b2b/add-car" class="bg-orange-500 hover:bg-orange-600 text-white font-bold px-5 py-2.5 rounded-xl transition-colors">
            Adaugă altă mașină
          </a>
          <a href="/b2b/dashboard" class="border-2 border-gray-200 hover:border-gray-300 text-gray-700 font-bold px-5 py-2.5 rounded-xl transition-colors">
            Dashboard
          </a>
        </div>
      </div>
    ) : (
      <div class="bg-white rounded-2xl shadow-md p-8">
        {error && (
          <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-3 mb-6 text-sm">{error}</div>
        )}

        <form method="POST" enctype="multipart/form-data" class="space-y-5">
          <h3 class="font-bold text-gray-700 border-b pb-2">Detalii mașină</h3>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Titlu anunț *</label>
            <input type="text" name="title" required class="form-input" placeholder="ex: BMW X5 xDrive30d 2021" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Marcă *</label>
              <input type="text" name="make" required class="form-input" placeholder="BMW" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Model *</label>
              <input type="text" name="model" required class="form-input" placeholder="X5" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">An fabricație *</label>
              <input type="number" name="year" required min="1990" max={currentYear} class="form-input" placeholder="2021" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Kilometri *</label>
              <input type="number" name="mileage" required min="0" class="form-input" placeholder="85000" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Combustibil</label>
              <select name="fuel_type" class="form-select">
                <option>Diesel</option><option>Benzină</option><option>Hibrid</option>
                <option>Electric</option><option>GPL</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Transmisie</label>
              <select name="transmission" class="form-select">
                <option>Automată</option><option>Manuală</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Caroserie</label>
              <select name="body_type" class="form-select">
                <option>SUV</option><option>Sedan</option><option>Hatchback</option>
                <option>Break</option><option>Coupe</option><option>Cabrio</option><option>Van</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Culoare</label>
              <input type="text" name="color" class="form-input" placeholder="Negru" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Motor (cm³)</label>
              <input type="text" name="engine_size" class="form-input" placeholder="2993" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Putere (CP)</label>
              <input type="number" name="power" class="form-input" placeholder="265" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Descriere</label>
            <textarea name="description" rows="4" class="form-input resize-none" placeholder="Stare excelentă, service la zi..."></textarea>
          </div>

          <h3 class="font-bold text-gray-700 border-b pb-2 pt-2">Preț</h3>
          <div class="bg-orange-50 border border-orange-200 rounded-xl p-5">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Prețul tău (€) *</label>
            <input
              type="number" name="original_price" id="original_price" required min="500"
              class="form-input text-xl font-bold" placeholder="10000"
            />
            <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
              <div class="bg-white rounded-lg p-3 text-center">
                <div class="text-gray-400 text-xs mb-1">Prețul tău</div>
                <div id="price-own" class="font-bold text-gray-700">—</div>
              </div>
              <div class="bg-orange-500 rounded-lg p-3 text-center text-white">
                <div class="text-orange-100 text-xs mb-1">Preț afișat pe site (+15%)</div>
                <div id="price-display" class="font-black text-lg">—</div>
              </div>
            </div>
            <p class="text-xs text-orange-600 mt-3">La vânzare primești prețul tău integral. Diferența de 15% reprezintă comisionul DAG Auto.</p>
          </div>

          <h3 class="font-bold text-gray-700 border-b pb-2 pt-2">Fotografii</h3>
          <div>
            <input type="file" name="images" multiple accept="image/*" class="form-input" />
            <p class="text-xs text-gray-400 mt-1">Prima fotografie va fi imaginea principală. Poți adăuga mai multe.</p>
          </div>

          <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-4 rounded-xl transition-colors text-lg">
            Trimite anunțul →
          </button>
        </form>
      </div>
    )}
  </div>

  <script>
    const input = document.getElementById('original_price') as HTMLInputElement;
    const priceOwn = document.getElementById('price-own')!;
    const priceDisplay = document.getElementById('price-display')!;
    input?.addEventListener('input', () => {
      const v = parseFloat(input.value) || 0;
      if (v > 0) {
        priceOwn.textContent = `${v.toLocaleString('ro-RO')} €`;
        priceDisplay.textContent = `${Math.round(v * 1.15).toLocaleString('ro-RO')} €`;
      } else {
        priceOwn.textContent = priceDisplay.textContent = '—';
      }
    });
  </script>
</B2BLayout>
