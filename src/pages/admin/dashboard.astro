---
import AdminLayout from '../../layouts/AdminLayout.astro';

const DB = Astro.locals.runtime?.env?.DB;

let stats = [
  { label: 'Mașini disponibile', value: 0, icon: '🚗', href: '/admin/masini' },
  { label: 'Articole blog', value: 0, icon: '📝', href: '/admin/blog' },
  { label: 'Formulare necitite', value: 0, icon: '📬', href: '/admin/submissions' },
];
let recentCars: any[] = [];
let recentSubmissions: any[] = [];
let dbError = '';

try {
  if (DB) {
    const [carsRes, postsRes, submissionsRes] = await Promise.all([
      DB.prepare('SELECT COUNT(*) as total FROM cars').first(),
      DB.prepare('SELECT COUNT(*) as total FROM blog_posts').first(),
      DB.prepare('SELECT COUNT(*) as total FROM form_submissions WHERE read_at IS NULL').first(),
    ]);
    stats = [
      { label: 'Mașini disponibile', value: (carsRes as any)?.total ?? 0, icon: '🚗', href: '/admin/masini' },
      { label: 'Articole blog', value: (postsRes as any)?.total ?? 0, icon: '📝', href: '/admin/blog' },
      { label: 'Formulare necitite', value: (submissionsRes as any)?.total ?? 0, icon: '📬', href: '/admin/submissions' },
    ];
    const carsResult = await DB.prepare('SELECT id, title, price, status, slug FROM cars ORDER BY id DESC LIMIT 5').all();
    recentCars = carsResult.results as any[];
    const subsResult = await DB.prepare('SELECT id, form_type, created_at, read_at FROM form_submissions ORDER BY created_at DESC LIMIT 5').all();
    recentSubmissions = subsResult.results as any[];
  }
} catch (e: any) {
  dbError = e?.message || String(e);
  console.error('Dashboard DB error:', e);
}
---

<AdminLayout title="Dashboard">
  <div class="space-y-8">
    {dbError && (
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-4 text-sm">
        ⚠️ Eroare DB: {dbError}
      </div>
    )}

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {stats.map(s => (
        <a href={s.href} class="bg-white rounded-xl shadow-sm p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
          <span class="text-4xl">{s.icon}</span>
          <div>
            <div class="text-3xl font-bold text-gray-800">{s.value}</div>
            <div class="text-sm text-gray-500">{s.label}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Quick actions -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="font-semibold text-gray-700 mb-4">Acțiuni Rapide</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/admin/masini/nou" class="btn-primary text-sm">+ Adaugă Mașină</a>
        <a href="/admin/blog/nou" class="btn-secondary text-sm">+ Articol Blog</a>
        <a href="/admin/submissions" class="btn-outline text-sm">📬 Vezi Formulare</a>
      </div>
    </div>

    <!-- Recent cars -->
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
      <div class="p-6 flex items-center justify-between border-b">
        <h2 class="font-semibold text-gray-700">Ultimele Mașini</h2>
        <a href="/admin/masini" class="text-sm text-orange-500 hover:underline">Vezi toate →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
            <tr>
              <th class="px-6 py-3 text-left">Titlu</th>
              <th class="px-6 py-3 text-left">Preț</th>
              <th class="px-6 py-3 text-left">Status</th>
              <th class="px-6 py-3 text-left">Acțiuni</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {recentCars.map((car: any) => (
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 font-medium text-gray-800">{car.title}</td>
                <td class="px-6 py-4 text-gray-600">{new Intl.NumberFormat('ro-RO').format(car.price)} €</td>
                <td class="px-6 py-4">
                  <span class={`px-2 py-1 rounded-full text-xs font-medium ${
                    car.status === 'available' ? 'bg-green-100 text-green-700' :
                    car.status === 'sold' ? 'bg-red-100 text-red-700' :
                    'bg-yellow-100 text-yellow-700'
                  }`}>{car.status}</span>
                </td>
                <td class="px-6 py-4">
                  <a href={`/admin/masini/${car.id}`} class="text-orange-500 hover:underline mr-3">Editează</a>
                </td>
              </tr>
            ))}
            {recentCars.length === 0 && (
              <tr><td colspan="4" class="px-6 py-8 text-center text-gray-400">
                Nicio mașină adăugată. <a href="/admin/masini/nou" class="text-orange-500 underline">Adaugă →</a>
              </td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent submissions -->
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
      <div class="p-6 flex items-center justify-between border-b">
        <h2 class="font-semibold text-gray-700">Ultimele Formulare</h2>
        <a href="/admin/submissions" class="text-sm text-orange-500 hover:underline">Vezi toate →</a>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
            <tr>
              <th class="px-6 py-3 text-left">Tip</th>
              <th class="px-6 py-3 text-left">Data</th>
              <th class="px-6 py-3 text-left">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {recentSubmissions.map((sub: any) => (
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 font-medium text-gray-800">{sub.form_type}</td>
                <td class="px-6 py-4 text-gray-600">{new Date(sub.created_at).toLocaleDateString('ro-RO')}</td>
                <td class="px-6 py-4">
                  <span class={`px-2 py-1 rounded-full text-xs ${sub.read_at ? 'bg-gray-100 text-gray-500' : 'bg-orange-100 text-orange-700 font-medium'}`}>
                    {sub.read_at ? 'Citit' : 'Nou'}
                  </span>
                </td>
              </tr>
            ))}
            {recentSubmissions.length === 0 && (
              <tr><td colspan="3" class="px-6 py-8 text-center text-gray-400">Niciun formular primit.</td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>
