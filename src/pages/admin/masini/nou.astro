---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createCar, generateSlug } from '../../../lib/db';

const DB = Astro.locals.runtime?.env?.DB;
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const title = data.get('title') as string;
    const slug = generateSlug(title) + '-' + Date.now().toString(36);

    const oldPrice = Number(data.get('old_price')) || 0;
    const featured = data.get('featured') === '1' ? 1 : 0;
    await DB.prepare(`
      INSERT INTO cars (title, slug, make, model, year, price, mileage, fuel_type, transmission, body_type, color, engine_size, power, description, features, status, old_price, featured, doors, seats, drivetrain, vin, country_origin, nr_owners, service_history, accident_free, euro_standard)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    `).bind(
      title, slug,
      data.get('make'), data.get('model'),
      Number(data.get('year')), Number(data.get('price')),
      Number(data.get('mileage')), data.get('fuel_type'),
      data.get('transmission'), data.get('body_type'),
      data.get('color') || '', data.get('engine_size') || '',
      Number(data.get('power')) || 0,
      data.get('description') || '', data.get('features') || '',
      data.get('status') || 'available',
      oldPrice, featured,
      Number(data.get('doors')) || 0,
      Number(data.get('seats')) || 5,
      data.get('drivetrain') || '',
      data.get('vin') || '',
      data.get('country_origin') || '',
      Number(data.get('nr_owners')) || 0,
      data.get('service_history') === '1' ? 1 : 0,
      data.get('accident_free') === '0' ? 0 : 1,
      data.get('euro_standard') || ''
    ).run();

    const newCar = await DB.prepare('SELECT id FROM cars ORDER BY id DESC LIMIT 1').first<{ id: number }>();
    return Astro.redirect(`/admin/masini/${newCar?.id}?saved=1`);
  } catch (e) {
    error = 'Eroare la salvare. Verifică datele introduse.';
  }
}
---

<AdminLayout title="Adaugă Mașină">
  <div class="max-w-3xl">
    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-4 mb-6">{error}</div>
    )}

    <form method="POST" class="space-y-6">
      <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
        <h2 class="font-semibold text-gray-700 border-b pb-2">Informații Generale</h2>
        <div>
          <label class="form-label">Titlu anunț *</label>
          <input type="text" name="title" required class="form-input" placeholder="ex: BMW X5 xDrive30d 2021 Full Option" />
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label">Marcă *</label>
            <input type="text" name="make" required class="form-input" placeholder="BMW" />
          </div>
          <div>
            <label class="form-label">Model *</label>
            <input type="text" name="model" required class="form-input" placeholder="X5" />
          </div>
        </div>
        <div class="grid sm:grid-cols-3 gap-4">
          <div>
            <label class="form-label">An fabricație *</label>
            <input type="number" name="year" required class="form-input" min="2000" max="2025" />
          </div>
          <div>
            <label class="form-label">Preț (€) *</label>
            <input type="number" name="price" required class="form-input" min="0" />
          </div>
          <div>
            <label class="form-label">Kilometraj *</label>
            <input type="number" name="mileage" required class="form-input" min="0" />
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
        <h2 class="font-semibold text-gray-700 border-b pb-2">Specificații Tehnice</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label">Combustibil *</label>
            <select name="fuel_type" required class="form-select">
              <option>Benzină</option>
              <option>Diesel</option>
              <option>Hibrid</option>
              <option>Electric</option>
              <option>GPL</option>
            </select>
          </div>
          <div>
            <label class="form-label">Transmisie *</label>
            <select name="transmission" required class="form-select">
              <option>Manuală</option>
              <option>Automată</option>
            </select>
          </div>
          <div>
            <label class="form-label">Caroserie *</label>
            <select name="body_type" required class="form-select">
              <option>Berlină</option>
              <option>Break</option>
              <option>SUV</option>
              <option>Hatchback</option>
              <option>Coupe</option>
              <option>Cabrio</option>
              <option>Monovolum</option>
              <option>Pickup</option>
            </select>
          </div>
          <div>
            <label class="form-label">Culoare</label>
            <input type="text" name="color" class="form-input" placeholder="Negru" />
          </div>
          <div>
            <label class="form-label">Motor (ex: 2.0 TDI)</label>
            <input type="text" name="engine_size" class="form-input" placeholder="2.0 TDI" />
          </div>
          <div>
            <label class="form-label">Putere (CP)</label>
            <input type="number" name="power" class="form-input" min="0" placeholder="190" />
          </div>
          <div>
            <label class="form-label">Tracțiune</label>
            <select name="drivetrain" class="form-select">
              <option value="">Nespecificat</option>
              <option>FWD (față)</option>
              <option>RWD (spate)</option>
              <option>4x4 / AWD</option>
            </select>
          </div>
          <div>
            <label class="form-label">Nr. uși</label>
            <select name="doors" class="form-select">
              <option value="0">Nespecificat</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5">5</option>
            </select>
          </div>
          <div>
            <label class="form-label">Nr. locuri</label>
            <input type="number" name="seats" class="form-input" min="2" max="9" placeholder="5" />
          </div>
          <div>
            <label class="form-label">Normă Euro</label>
            <select name="euro_standard" class="form-select">
              <option value="">Nespecificat</option>
              <option>Euro 3</option>
              <option>Euro 4</option>
              <option>Euro 5</option>
              <option>Euro 6</option>
              <option>Euro 6d</option>
            </select>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
        <h2 class="font-semibold text-gray-700 border-b pb-2">Istoric & Proveniență</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label">VIN (opțional)</label>
            <input type="text" name="vin" class="form-input" placeholder="WVWZZZ1KZ..." maxlength="17" />
          </div>
          <div>
            <label class="form-label">Țara de origine</label>
            <input type="text" name="country_origin" class="form-input" placeholder="Germania" />
          </div>
          <div>
            <label class="form-label">Nr. proprietari anteriori</label>
            <input type="number" name="nr_owners" class="form-input" min="0" max="20" placeholder="1" />
          </div>
          <div class="flex flex-col gap-3 mt-6">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="service_history" value="1" class="w-4 h-4 accent-orange-500" />
              <span class="form-label mb-0">Istoric service disponibil</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="accident_free" value="0" class="w-4 h-4 accent-red-500" />
              <span class="form-label mb-0 text-red-600">Are accident în istoric</span>
            </label>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
        <h2 class="font-semibold text-gray-700 border-b pb-2">Descriere și Dotări</h2>
        <div>
          <label class="form-label">Descriere</label>
          <textarea name="description" rows="5" class="form-input resize-none" placeholder="Descrie starea mașinii, istoricul, dotările speciale..."></textarea>
        </div>
        <div>
          <label class="form-label">Dotări (separate prin virgulă)</label>
          <textarea name="features" rows="3" class="form-input resize-none" placeholder="Navigație, Camere 360, Scaune încălzite, Panoramic..."></textarea>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
        <h2 class="font-semibold text-gray-700 border-b pb-2">Preț și Promoție</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label">Preț vechi (€) <span class="text-gray-400 font-normal">— pentru badge Reducere</span></label>
            <input type="number" name="old_price" class="form-input" min="0" placeholder="0 = fără reducere" />
          </div>
          <div class="flex items-center gap-3 mt-6">
            <input type="checkbox" name="featured" id="featured" value="1" class="w-5 h-5 accent-orange-500" />
            <label for="featured" class="form-label mb-0 cursor-pointer">⭐ Mașină Recomandată (afișată în top)</label>
          </div>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 flex gap-4 items-start">
        <div class="text-3xl">📸</div>
        <div>
          <p class="font-semibold text-blue-800 mb-1">Fotografiile se adaugă după salvare</p>
          <p class="text-sm text-blue-700">Completează datele mașinii și apasă <strong>Salvează</strong>. Pe pagina următoare vei putea încărca fotografii direct de pe calculator — multiple poze simultan, drag &amp; drop.</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="font-semibold text-gray-700 border-b pb-2 mb-4">Status</h2>
        <select name="status" class="form-select max-w-xs">
          <option value="available">Disponibil</option>
          <option value="reserved">Rezervat</option>
          <option value="sold">Vândut</option>
        </select>
      </div>

      <div class="flex gap-4">
        <button type="submit" class="btn-primary">Salvează Mașina →</button>
        <a href="/admin/masini" class="btn-outline">Anulează</a>
      </div>
    </form>
  </div>
</AdminLayout>
