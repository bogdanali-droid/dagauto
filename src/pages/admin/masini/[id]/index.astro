---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getCarById, getCarImages, updateCar } from '../../../../lib/db';

const DB = Astro.locals.runtime?.env?.DB;
const id = Number(Astro.params.id);

const car = await getCarById(DB, id);
if (!car) return Astro.redirect('/admin/masini');

const { results: images } = await getCarImages(DB, id);
let error = '';
let saved = Astro.url.searchParams.get('saved') === '1';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    await updateCar(DB, id, {
      title: data.get('title') as string,
      make: data.get('make') as string,
      model: data.get('model') as string,
      year: Number(data.get('year')),
      price: Number(data.get('price')),
      mileage: Number(data.get('mileage')),
      fuel_type: data.get('fuel_type') as string,
      transmission: data.get('transmission') as string,
      body_type: data.get('body_type') as string,
      color: data.get('color') as string,
      engine_size: data.get('engine_size') as string,
      power: Number(data.get('power')),
      description: data.get('description') as string,
      features: data.get('features') as string,
      status: data.get('status') as 'available' | 'sold' | 'reserved',
    });
    return Astro.redirect(`/admin/masini/${id}?saved=1`);
  } catch (e) {
    error = 'Eroare la salvare.';
  }
}
---

<AdminLayout title={`Editează: ${car.title}`}>
  <div class="max-w-4xl space-y-6">
    {saved && <div class="bg-green-50 border border-green-200 text-green-700 rounded-lg p-4">✅ Mașina a fost salvată!</div>}
    {error && <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-4">{error}</div>}

    <!-- Images section -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="font-semibold text-gray-700 border-b pb-2 mb-4">Imagini ({images.length})</h2>
      <div id="img-grid" class="grid grid-cols-3 sm:grid-cols-5 gap-3 mb-4">
        {images.map(img => (
          <div class="relative group">
            <img src={img.image_url} alt="" class="w-full aspect-square object-cover rounded-lg" />
            {img.is_primary === 1 && (
              <span class="absolute top-1 left-1 bg-orange-500 text-white text-xs px-1.5 py-0.5 rounded">Principal</span>
            )}
            <button
              type="button"
              onclick={`deleteImage(${img.id})`}
              class="absolute top-1 right-1 bg-red-500 text-white rounded-full w-6 h-6 text-xs hidden group-hover:flex items-center justify-center"
            >✕</button>
          </div>
        ))}
        {images.length === 0 && (
          <div class="col-span-5 text-sm text-gray-400 py-4 text-center" data-no-images>Nicio imagine adăugată.</div>
        )}
      </div>

      <!-- Upload zone -->
      <div
        id="drop-zone"
        class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center cursor-pointer hover:border-orange-400 hover:bg-orange-50 transition-colors"
        onclick="document.getElementById('image-file').click()"
        ondragover="event.preventDefault();this.classList.add('border-orange-400','bg-orange-50')"
        ondragleave="this.classList.remove('border-orange-400','bg-orange-50')"
        ondrop="handleDrop(event)"
      >
        <div class="text-4xl mb-2">📁</div>
        <p class="font-semibold text-gray-700">Trage pozele aici sau apasă pentru a selecta</p>
        <p class="text-sm text-gray-400 mt-1">JPG, PNG, WEBP — max 10MB per poză — multiple simultan</p>
        <input type="file" id="image-file" name="file" accept="image/*" multiple class="hidden" onchange="uploadImages(this.files)" />
      </div>
      <div id="upload-progress" class="hidden mt-3 space-y-1"></div>
      <p id="upload-status" class="text-sm mt-2 font-medium"></p>
    </div>

    <!-- Edit form -->
    <form method="POST" class="space-y-6">
      <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
        <h2 class="font-semibold text-gray-700 border-b pb-2">Informații Generale</h2>
        <div>
          <label class="form-label">Titlu anunț *</label>
          <input type="text" name="title" required class="form-input" value={car.title} />
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label">Marcă *</label>
            <input type="text" name="make" required class="form-input" value={car.make} />
          </div>
          <div>
            <label class="form-label">Model *</label>
            <input type="text" name="model" required class="form-input" value={car.model} />
          </div>
        </div>
        <div class="grid sm:grid-cols-3 gap-4">
          <div>
            <label class="form-label">An *</label>
            <input type="number" name="year" required class="form-input" value={car.year} />
          </div>
          <div>
            <label class="form-label">Preț (€) *</label>
            <input type="number" name="price" required class="form-input" value={car.price} />
          </div>
          <div>
            <label class="form-label">Kilometraj *</label>
            <input type="number" name="mileage" required class="form-input" value={car.mileage} />
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
        <h2 class="font-semibold text-gray-700 border-b pb-2">Specificații</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="form-label">Combustibil</label>
            <select name="fuel_type" class="form-select">
              {['Benzină','Diesel','Hibrid','Electric','GPL'].map(f => (
                <option selected={car.fuel_type === f}>{f}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="form-label">Transmisie</label>
            <select name="transmission" class="form-select">
              {['Manuală','Automată'].map(t => (
                <option selected={car.transmission === t}>{t}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="form-label">Caroserie</label>
            <select name="body_type" class="form-select">
              {['Berlină','Break','SUV','Hatchback','Coupe','Cabrio','Monovolum','Pickup'].map(b => (
                <option selected={car.body_type === b}>{b}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="form-label">Culoare</label>
            <input type="text" name="color" class="form-input" value={car.color} />
          </div>
          <div>
            <label class="form-label">Motor</label>
            <input type="text" name="engine_size" class="form-input" value={car.engine_size} />
          </div>
          <div>
            <label class="form-label">Putere (CP)</label>
            <input type="number" name="power" class="form-input" value={car.power} />
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6 space-y-4">
        <h2 class="font-semibold text-gray-700 border-b pb-2">Descriere și Dotări</h2>
        <div>
          <label class="form-label">Descriere</label>
          <textarea name="description" rows="5" class="form-input resize-none">{car.description}</textarea>
        </div>
        <div>
          <label class="form-label">Dotări (separate prin virgulă)</label>
          <textarea name="features" rows="3" class="form-input resize-none">{car.features}</textarea>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="font-semibold text-gray-700 border-b pb-2 mb-4">Status</h2>
        <select name="status" class="form-select max-w-xs">
          {(['available','reserved','sold'] as const).map(s => (
            <option value={s} selected={car.status === s}>
              {s === 'available' ? 'Disponibil' : s === 'reserved' ? 'Rezervat' : 'Vândut'}
            </option>
          ))}
        </select>
      </div>

      <div class="flex gap-4">
        <button type="submit" class="btn-primary">Salvează Modificările →</button>
        <a href="/admin/masini" class="btn-outline">Înapoi</a>
        <form method="POST" action={`/admin/masini/${id}/delete`} class="ml-auto"
              onsubmit="return confirm('Ești sigur că vrei să ștergi această mașină?')">
          <button type="submit" class="text-red-500 hover:text-red-700 text-sm underline">
            Șterge mașina
          </button>
        </form>
      </div>
    </form>
  </div>
</AdminLayout>

<script define:vars={{ carId: id }}>
function handleDrop(e) {
  e.preventDefault();
  document.getElementById('drop-zone').classList.remove('border-orange-400','bg-orange-50');
  const files = e.dataTransfer?.files;
  if (files && files.length > 0) uploadImages(files);
}

async function uploadImages(files) {
  if (!files) files = document.getElementById('image-file').files;
  const status = document.getElementById('upload-status');
  const progress = document.getElementById('upload-progress');
  if (!files || files.length === 0) return;

  const noImages = document.querySelector('[data-no-images]');
  if (noImages) noImages.remove();

  progress.classList.remove('hidden');
  status.textContent = '';

  // Check if car has images already (for is_primary logic)
  const hasImages = document.querySelectorAll('#img-grid > div').length > 0;

  for (let i = 0; i < files.length; i++) {
    const bar = document.createElement('div');
    bar.className = 'flex items-center gap-2 text-sm';
    bar.innerHTML = `<span class="truncate max-w-xs text-gray-600">${files[i].name}</span><span class="text-orange-500 animate-pulse">Se încarcă...</span>`;
    progress.appendChild(bar);

    const fd = new FormData();
    fd.append('file', files[i]);
    fd.append('car_id', String(carId));
    fd.append('is_primary', String(!hasImages && i === 0 ? 'true' : 'false'));
    fd.append('sort_order', String(i));

    const res = await fetch('/api/upload-image', { method: 'POST', body: fd });
    if (res.ok) {
      const data = await res.json();
      bar.innerHTML = `<span class="truncate max-w-xs text-gray-600">${files[i].name}</span><span class="text-green-600">✓ Ok</span>`;
      // Add thumbnail to grid immediately
      const grid = document.getElementById('img-grid');
      const div = document.createElement('div');
      div.className = 'relative group';
      div.innerHTML = `<img src="${data.url}" class="w-full aspect-square object-cover rounded-lg" />${!hasImages && i === 0 ? '<span class="absolute top-1 left-1 bg-orange-500 text-white text-xs px-1.5 py-0.5 rounded">Principal</span>' : ''}`;
      grid?.appendChild(div);
    } else {
      bar.innerHTML = `<span class="truncate max-w-xs text-gray-600">${files[i].name}</span><span class="text-red-500">✗ Eroare</span>`;
    }
  }
  status.textContent = '✅ Toate pozele au fost încărcate!';
  status.className = 'text-sm mt-2 font-medium text-green-600';
  setTimeout(() => { progress.classList.add('hidden'); progress.innerHTML = ''; status.textContent = ''; }, 3000);
}

async function deleteImage(imageId) {
  if (!confirm('Ștergi imaginea?')) return;
  const res = await fetch('/api/delete-image', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ image_id: imageId }),
  });
  if (res.ok) location.reload();
  else alert('Eroare la ștergere.');
}
</script>
